---
import SectionHead from "./SectionHead.astro";

// Answer-first: every answer's first sentence is extractable on its own.
export const faqs = [
  {
    q: "How much does a custom website cost?",
    a: "Three fixed prices: a one-page Launch Page is $500 flat, the full Conversion-Engineered Site starts at $4,500, and monthly Growth Engine optimization starts at $750 a month. Scope and price are locked before the build starts, so there are no hourly surprises.",
  },
  {
    q: "How long does a website take to build?",
    a: "21 days from kickoff to live, guaranteed: if I miss the date you do not pay the balance until it ships. The Launch Page goes live in 7 days.",
  },
  {
    q: "Do I own the website when it's done?",
    a: "Yes, all of it: domain, code, and content, with free hosting at $0 a month. Nothing is held hostage, and you can leave anytime and take everything with you.",
  },
  {
    q: "What if I don't like the design?",
    a: "You get your deposit back. You see a real design direction before committing, and if it is not right, the deposit returns with no pressure and no awkward follow-ups.",
  },
  {
    q: "Do you handle SEO and AI search too?",
    a: "Yes. The Growth Engine covers nine surfaces monthly: SEO, AEO, GEO, voice, performance, CRO, email deliverability, and social, with fixes shipped rather than suggested. The full breakdown lives on the SEO service page.",
  },
];
---

<section id="faq" class="px-6 sm:px-12 lg:px-20 pt-28 sm:pt-36 pb-24">
  <div class="max-w-7xl mx-auto">
    <SectionHead
      fig="09"
      name="specifications"
      title="Straight answers, <em>before you even ask.</em>"
    />

    <div class="grid gap-12 lg:grid-cols-[minmax(0,48rem)_1fr] lg:items-start">
      <div>
        {
          faqs.map((f, i) => (
            <details
              class="cascade-card group border-t border-border"
              style={`--cascade-i: ${i}`}
            >
              <summary class="flex min-h-[56px] cursor-pointer list-none items-center justify-between gap-6 py-5 [&::-webkit-details-marker]:hidden">
                <h3 class="font-display text-lg sm:text-xl font-medium text-text">
                  {f.q}
                </h3>
                <span
                  class="mono-note shrink-0 !text-accent transition-transform duration-300 group-open:rotate-45"
                  style="transition-timing-function: var(--ease-out-expo)"
                  aria-hidden="true"
                >
                  +
                </span>
              </summary>
              <p class="max-w-2xl pb-6 text-sm sm:text-base text-text-muted">
                {f.a}
              </p>
            </details>
          ))
        }
        <div class="rule-draw"></div>
        <p class="mono-note mt-6">
          different question? <a
            href="mailto:russ@generuss.com"
            class="link-draft !text-accent inline-flex min-h-[44px] items-center -my-3"
            >russ@generuss.com</a
          > answers same-day.
        </p>
      </div>

      <!-- at-a-glance rail -->
      <aside
        class="rise hidden lg:block lg:sticky lg:top-28 lg:ml-auto lg:w-56"
        aria-label="Specs at a glance"
      >
        <div class="note-rule">
          <p class="fig-label mb-3">Fig. 09a / at a glance</p>
          <dl class="space-y-3">
            {
              [
                ["$500", "launch page, flat"],
                ["$4,500", "flagship, from"],
                ["21 days", "or the balance is $0"],
                ["$0/mo", "hosting, forever"],
                ["100%", "yours when it ships"],
              ].map(([v, k]) => (
                <div class="flex items-baseline justify-between gap-3">
                  <dt class="mono-note order-2 text-right">{k}</dt>
                  <dd class="font-display text-lg font-medium text-text">
                    {v}
                  </dd>
                </div>
              ))
            }
          </dl>
        </div>
      </aside>
    </div>
  </div>
</section>
