---
interface Props {
  alwaysVisible?: boolean;
}

// alwaysVisible was the legacy gate. Keeping the prop for blog pages but ignoring it on the main page.
// Per Akki + Jack feedback: nav must be visible on first paint with logo, no scroll-gated reveal.
const { alwaysVisible = false } = Astro.props;
---

<nav
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-shadow duration-300 backdrop-blur-md bg-bg/80 border-b border-border/50"
  style={`padding-top: env(safe-area-inset-top, 0px);`}
  aria-label="Main navigation"
  data-always-visible={alwaysVisible ? "true" : "false"}
>
  <div class="flex items-center justify-between px-6 sm:px-10 lg:px-16 h-16">
    <!-- Logo (always visible above the fold) -->
    <a
      href="/"
      class="inline-flex items-center gap-2 text-text hover:text-accent transition-colors duration-200 group min-h-[44px] py-2"
      aria-label="generuss design - home"
    >
      <svg
        viewBox="0 0 32 32"
        width="28"
        height="28"
        class="shrink-0"
        aria-hidden="true"
      >
        <rect width="32" height="32" rx="6" fill="#1A1A1E"></rect>
        <text
          x="4"
          y="26"
          font-family="Inter, system-ui, sans-serif"
          font-size="28"
          font-weight="900"
          fill="currentColor"
          class="text-text group-hover:text-accent transition-colors">g</text
        >
        <circle cx="24" cy="24" r="3" fill="#00FFEF"></circle>
      </svg>
      <span class="text-lg font-bold tracking-tight"
        >generuss<span class="text-accent">.</span></span
      >
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-7">
      <a
        href="/#portfolio"
        class="nav-link text-sm text-text-muted hover:text-text transition-colors duration-200"
        >Work</a
      >
      <a
        href="/#offer"
        class="nav-link text-sm text-text-muted hover:text-text transition-colors duration-200"
        >Offer</a
      >
      <a
        href="/#about"
        class="nav-link text-sm text-text-muted hover:text-text transition-colors duration-200"
        >About</a
      >
      <a
        href="/blog"
        class="text-sm text-text-muted hover:text-text transition-colors duration-200"
        >Blog</a
      >
      <a
        href="/#booking"
        class="rounded-full bg-accent px-5 py-2 text-sm font-semibold text-[#0C0C0C] min-h-[44px] inline-flex items-center transition-shadow duration-200 hover:shadow-[0_0_20px_var(--color-accent-mid)]"
      >
        Book a Call
      </a>
    </div>

    <!-- Mobile: CTA + Hamburger -->
    <div class="flex items-center gap-3 md:hidden">
      <a
        href="/#booking"
        class="rounded-full bg-accent px-4 py-2 text-xs font-semibold text-[#0C0C0C] min-h-[44px] inline-flex items-center"
      >
        Book a Call
      </a>
      <button
        id="hamburger"
        type="button"
        class="flex h-11 w-11 items-center justify-center rounded-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <span class="hamburger-bars relative block h-5 w-6">
          <span
            class="absolute left-0 top-0 h-0.5 w-full bg-text transition-[transform,opacity] duration-200"
          ></span>
          <span
            class="absolute left-0 top-[9px] h-0.5 w-full bg-text transition-[transform,opacity] duration-200"
          ></span>
          <span
            class="absolute left-0 bottom-0 h-0.5 w-full bg-text transition-[transform,opacity] duration-200"
          ></span>
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 top-0 z-40 hidden flex-col items-center justify-center gap-8 bg-bg/95 backdrop-blur-lg"
    style={`padding-top: env(safe-area-inset-top, 0px); padding-bottom: env(safe-area-inset-bottom, 0px);`}
    role="dialog"
    aria-modal="true"
    aria-label="Mobile navigation"
  >
    <a
      href="/#portfolio"
      class="mobile-nav-link text-2xl font-semibold text-text hover:text-accent transition-colors"
      >Work</a
    >
    <a
      href="/#offer"
      class="mobile-nav-link text-2xl font-semibold text-text hover:text-accent transition-colors"
      >Offer</a
    >
    <a
      href="/#about"
      class="mobile-nav-link text-2xl font-semibold text-text hover:text-accent transition-colors"
      >About</a
    >
    <a
      href="/blog"
      class="mobile-nav-link text-2xl font-semibold text-text hover:text-accent transition-colors"
      >Blog</a
    >
    <a
      href="/#booking"
      class="mt-4 rounded-full bg-accent px-8 py-3 text-lg font-semibold text-[#0C0C0C] min-h-[44px] inline-flex items-center"
    >
      Book a Call
    </a>
  </div>
</nav>

<script>
  const nav = document.getElementById("site-nav");
  const hamburger = document.getElementById("hamburger");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileLinks = mobileMenu?.querySelectorAll("a");

  // Mobile menu toggle (no GSAP needed)
  function openMenu() {
    mobileMenu?.classList.remove("hidden");
    mobileMenu?.classList.add("flex");
    hamburger?.setAttribute("aria-expanded", "true");
    hamburger?.setAttribute("aria-label", "Close menu");
    document.body.style.overflow = "hidden";
    (mobileLinks?.[0] as HTMLElement)?.focus();
  }

  function closeMenu() {
    mobileMenu?.classList.add("hidden");
    mobileMenu?.classList.remove("flex");
    hamburger?.setAttribute("aria-expanded", "false");
    hamburger?.setAttribute("aria-label", "Open menu");
    document.body.style.overflow = "";
    hamburger?.focus();
  }

  hamburger?.addEventListener("click", () => {
    const isOpen = hamburger.getAttribute("aria-expanded") === "true";
    isOpen ? closeMenu() : openMenu();
  });

  mobileLinks?.forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  document.addEventListener("keydown", (e) => {
    if (hamburger?.getAttribute("aria-expanded") !== "true") return;

    if (e.key === "Escape") {
      closeMenu();
      return;
    }

    if (e.key === "Tab" && mobileLinks?.length) {
      const first = mobileLinks[0] as HTMLElement;
      const last = mobileLinks[mobileLinks.length - 1] as HTMLElement;
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });

  // Nav is always visible from first paint now (per conversion-funnel rebuild).
  // Lightweight scroll-state toggle adds extra shadow + opacity when scrolled past the hero.
  // Active section tracking via IntersectionObserver - no GSAP/ScrollTrigger needed.
  if (nav) {
    // Stronger backdrop after scrolling past first viewport
    let scrolled = false;
    const updateScrollState = () => {
      const isScrolled = window.scrollY > 80;
      if (isScrolled !== scrolled) {
        scrolled = isScrolled;
        nav.classList.toggle("shadow-[0_4px_20px_rgba(0,0,0,0.5)]", isScrolled);
        nav.classList.toggle("bg-bg/95", isScrolled);
        nav.classList.toggle("bg-bg/80", !isScrolled);
      }
    };
    window.addEventListener("scroll", updateScrollState, { passive: true });

    // Active section tracking (lightweight, no GSAP)
    const navLinks = document.querySelectorAll(".nav-link");
    const sections = ["portfolio", "offer", "about"];

    const setActive = (id: string) => {
      navLinks.forEach((link) => {
        const isMatch = link.getAttribute("href")?.includes(id);
        link.classList.toggle("text-accent", isMatch);
        link.classList.toggle("text-text-muted", !isMatch);
      });
    };

    if ("IntersectionObserver" in window) {
      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
            }
          });
        },
        { rootMargin: "-40% 0px -55% 0px" },
      );

      sections.forEach((id) => {
        const section = document.getElementById(id);
        if (section) sectionObserver.observe(section);
      });
    }
  }
</script>
