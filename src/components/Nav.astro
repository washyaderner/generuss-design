---
interface Props {
  alwaysVisible?: boolean;
}

const { alwaysVisible = false } = Astro.props;
---

<nav
  id="site-nav"
  class:list={[
    "fixed top-0 left-0 right-0 z-50 transition-all duration-300",
    "backdrop-blur-md bg-bg/70 border-b border-border/50",
    { "opacity-0 -translate-y-full": !alwaysVisible },
  ]}
  style={`padding-top: env(safe-area-inset-top, 0px);`}
  aria-label="Main navigation"
>
  <div class="flex items-center justify-between px-8 sm:px-12 lg:px-20 h-16">
    <!-- Logo -->
    <a
      href="/"
      class="text-lg font-bold text-text hover:text-accent transition-colors duration-200"
    >
      generuss<span class="text-accent">.</span>
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-8">
      <a
        href="/#services"
        class="nav-link text-sm text-text-muted hover:text-text transition-colors duration-200"
        >Work</a
      >
      <a
        href="/#about"
        class="nav-link text-sm text-text-muted hover:text-text transition-colors duration-200"
        >About</a
      >
      <a
        href="/blog"
        class="text-sm text-text-muted hover:text-text transition-colors duration-200"
        >Blog</a
      >
      <a
        href="/#booking"
        class="rounded-full bg-accent px-5 py-2 text-sm font-semibold text-[#0C0C0C] transition-shadow duration-200 hover:shadow-[0_0_20px_var(--color-accent-mid)]"
      >
        Book a Call
      </a>
    </div>

    <!-- Mobile: CTA + Hamburger -->
    <div class="flex items-center gap-4 md:hidden">
      <a
        href="/#booking"
        class="rounded-full bg-accent px-4 py-1.5 text-xs font-semibold text-[#0C0C0C]"
      >
        Book a Call
      </a>
      <button
        id="hamburger"
        type="button"
        class="flex h-11 w-11 items-center justify-center rounded-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <span class="hamburger-bars relative block h-5 w-6">
          <span
            class="absolute left-0 top-0 h-0.5 w-full bg-text transition-all duration-200"
          ></span>
          <span
            class="absolute left-0 top-[9px] h-0.5 w-full bg-text transition-all duration-200"
          ></span>
          <span
            class="absolute left-0 bottom-0 h-0.5 w-full bg-text transition-all duration-200"
          ></span>
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 top-0 z-40 hidden flex-col items-center justify-center gap-8 bg-bg/95 backdrop-blur-lg"
    style={`padding-top: env(safe-area-inset-top, 0px); padding-bottom: env(safe-area-inset-bottom, 0px);`}
    role="dialog"
    aria-modal="true"
    aria-label="Mobile navigation"
  >
    <a
      href="/#services"
      class="mobile-nav-link text-2xl font-semibold text-text hover:text-accent transition-colors"
      >Work</a
    >
    <a
      href="/#about"
      class="mobile-nav-link text-2xl font-semibold text-text hover:text-accent transition-colors"
      >About</a
    >
    <a
      href="/blog"
      class="mobile-nav-link text-2xl font-semibold text-text hover:text-accent transition-colors"
      >Blog</a
    >
    <a
      href="/#booking"
      class="mt-4 rounded-full bg-accent px-8 py-3 text-lg font-semibold text-[#0C0C0C]"
    >
      Book a Call
    </a>
  </div>
</nav>

<script>
  const nav = document.getElementById("site-nav");
  const hamburger = document.getElementById("hamburger");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileLinks = mobileMenu?.querySelectorAll("a");
  const isAlwaysVisible = nav?.classList.contains("opacity-0") === false;

  // Mobile menu toggle (no GSAP needed)
  function openMenu() {
    mobileMenu?.classList.remove("hidden");
    mobileMenu?.classList.add("flex");
    hamburger?.setAttribute("aria-expanded", "true");
    hamburger?.setAttribute("aria-label", "Close menu");
    document.body.style.overflow = "hidden";
    (mobileLinks?.[0] as HTMLElement)?.focus();
  }

  function closeMenu() {
    mobileMenu?.classList.add("hidden");
    mobileMenu?.classList.remove("flex");
    hamburger?.setAttribute("aria-expanded", "false");
    hamburger?.setAttribute("aria-label", "Open menu");
    document.body.style.overflow = "";
    hamburger?.focus();
  }

  hamburger?.addEventListener("click", () => {
    const isOpen = hamburger.getAttribute("aria-expanded") === "true";
    isOpen ? closeMenu() : openMenu();
  });

  mobileLinks?.forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  document.addEventListener("keydown", (e) => {
    if (hamburger?.getAttribute("aria-expanded") !== "true") return;

    if (e.key === "Escape") {
      closeMenu();
      return;
    }

    if (e.key === "Tab" && mobileLinks?.length) {
      const first = mobileLinks[0] as HTMLElement;
      const last = mobileLinks[mobileLinks.length - 1] as HTMLElement;
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });

  // Scroll-based show/hide + active section tracking (main page only)
  // Dynamically import GSAP so blog pages don't pay the ~45KB gzip cost
  if (!isAlwaysVisible && nav) {
    import("gsap").then(({ gsap }) => {
      import("gsap/ScrollTrigger").then(({ ScrollTrigger }) => {
        gsap.registerPlugin(ScrollTrigger);

        const showNav = () => {
          nav.classList.remove("opacity-0", "-translate-y-full");
        };
        const hideNav = () => {
          nav.classList.add("opacity-0", "-translate-y-full");
        };

        ScrollTrigger.create({
          trigger: "#hero",
          start: "bottom top+=100",
          onEnter: showNav,
          onLeaveBack: hideNav,
        });

        // Active section tracking
        const navLinks = document.querySelectorAll(".nav-link");
        const sections = ["services", "about"];

        function setActive(id: string) {
          navLinks.forEach((link) => {
            if (link.getAttribute("href")?.includes(id)) {
              link.classList.add("text-accent");
              link.classList.remove("text-text-muted");
            }
          });
        }

        function clearActive(id: string) {
          navLinks.forEach((link) => {
            if (link.getAttribute("href")?.includes(id)) {
              link.classList.remove("text-accent");
              link.classList.add("text-text-muted");
            }
          });
        }

        sections.forEach((id) => {
          const section = document.getElementById(id);
          if (!section) return;

          ScrollTrigger.create({
            trigger: section,
            start: "top center",
            end: "bottom center",
            onEnter: () => setActive(id),
            onEnterBack: () => setActive(id),
            onLeave: () => clearActive(id),
            onLeaveBack: () => clearActive(id),
          });
        });
      });
    });
  }
</script>
