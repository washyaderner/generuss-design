---
// The footer is the sheet's titleblock: every working drawing gets signed.
const year = new Date().getFullYear();
---

<footer
  class="relative border-t-2 border-ink px-6 sm:px-12 lg:px-20 pt-12 pb-10"
  style={`padding-bottom: max(2.5rem, env(safe-area-inset-bottom, 0px));`}
>
  <div class="grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
    <!-- Brand / titleblock identity -->
    <nav
      class="footer-column col-span-2 sm:col-span-2 lg:col-span-1"
      aria-label="Brand"
    >
      <a
        href="/"
        class="inline-flex items-center gap-2 text-lg text-text min-h-[44px]"
      >
        <svg viewBox="0 0 32 32" width="24" height="24" aria-hidden="true">
          <rect
            x="1"
            y="1"
            width="30"
            height="30"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"></rect>
          <text
            x="6.5"
            y="24"
            font-family="Georgia, serif"
            font-style="italic"
            font-size="22"
            font-weight="600"
            fill="currentColor">g</text
          >
          <path
            d="M 24 28 L 30 28 M 27 25 L 27 31"
            stroke="oklch(0.5 0.085 245)"
            stroke-width="1.2"></path>
        </svg>
        <span class="font-display font-semibold"
          >generuss<span class="text-accent">.</span></span
        >
      </a>
      <p class="mt-4 text-sm text-text-muted leading-relaxed max-w-xs">
        Custom websites that close leads while you sleep. Hand-built in 21 days.
      </p>
      <p class="mono-note mt-4">
        Live in 21 days. Love it or your deposit back.<br />You own everything.
      </p>
    </nav>

    <!-- Site Nav -->
    <nav class="footer-column" aria-label="Site sections">
      <h3 class="fig-label mb-4 !text-text-muted">Sheet index</h3>
      <ul class="space-y-1">
        <li>
          <a
            href="/"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >Home</a
          >
        </li>
        <li>
          <a
            href="/#portfolio"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >Work</a
          >
        </li>
        <li>
          <a
            href="/#offer"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >Offer</a
          >
        </li>
        <li>
          <a
            href="/#about"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >About</a
          >
        </li>
        <li>
          <a
            href="/process"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >Process</a
          >
        </li>
        <li>
          <a
            href="/blog"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >Blog</a
          >
        </li>
      </ul>
    </nav>

    <!-- Services -->
    <nav class="footer-column" aria-label="Services">
      <h3 class="fig-label mb-4 !text-text-muted">Services</h3>
      <ul class="space-y-1">
        <li>
          <a
            href="/#offer"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >Custom website builds</a
          >
        </li>
        <li>
          <a
            href="/#offer"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >Conversion engineering</a
          >
        </li>
        <li>
          <a
            href="/seo"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >SEO, AEO + GEO optimization</a
          >
        </li>
        <li>
          <a
            href="/event-websites"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >Event + conference websites</a
          >
        </li>
        <li>
          <a
            href="/taste-audit"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >Website Taste Audit, $197</a
          >
        </li>
        <li>
          <a
            href="/compare"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >Compare your options</a
          >
        </li>
        <li>
          <a
            href="https://pharallax.ai"
            target="_blank"
            rel="noopener noreferrer"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >Pharallax strategic AI</a
          >
        </li>
        <li>
          <a
            href="/connect"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >Connect</a
          >
        </li>
      </ul>
    </nav>

    <!-- Get in touch -->
    <nav class="footer-column" aria-label="Get in touch">
      <h3 class="fig-label mb-4 !text-text-muted">Get in touch</h3>
      <ul class="space-y-1">
        <li>
          <a
            href="/#booking"
            class="link-draft inline-flex items-center py-1.5 text-sm font-medium text-accent min-h-[44px]"
            >Book a discovery call</a
          >
        </li>
        <li>
          <a
            href="mailto:russ@generuss.com"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >russ@generuss.com</a
          >
        </li>
        <li>
          <a
            href="https://github.com/washyaderner"
            target="_blank"
            rel="noopener noreferrer"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >GitHub</a
          >
        </li>
        <li>
          <a
            href="https://x.com/generussai"
            target="_blank"
            rel="noopener noreferrer"
            class="link-draft inline-flex items-center py-1.5 text-sm text-text-muted hover:text-text min-h-[44px]"
            >X / Twitter</a
          >
        </li>
      </ul>
    </nav>
  </div>

  <!-- Titleblock signature strip -->
  <div class="mt-12 border-t border-border pt-5">
    <div class="flex flex-wrap items-center justify-between gap-x-8 gap-y-3">
      <p class="mono-note !text-text-muted">drawn, not generated</p>
      <p class="mono-note">
        checked: <span class="font-display italic text-base text-text"
          >Russ Gardner</span
        >
        <span
          class="ml-2 inline-block h-2.5 w-2.5 rounded-full border border-seal align-middle"
          style="background: var(--color-seal-dim);"
          aria-hidden="true"></span>
      </p>
      <p class="mono-note !text-text-muted">tolerance: zero template parts</p>
      <p class="mono-note !text-text-muted">&copy; {year} generuss design</p>
    </div>
  </div>
</footer>
