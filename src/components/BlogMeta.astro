---
interface Props {
  date: string;
  tags?: string[];
  readingTime?: number;
}

const { date, tags = [], readingTime } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<div
  class="flex flex-wrap items-center gap-3 font-mono text-xs text-text-muted"
>
  <time datetime={date}>{formattedDate}</time>
  {readingTime && <span>&middot; {readingTime} min read</span>}
  {
    tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="border border-accent/30 rounded-full px-2 py-0.5 text-accent">
            {tag}
          </span>
        ))}
      </div>
    )
  }
</div>
