---
interface Props {
  url?: string;
}

const { url = "https://app.cal.com/generuss/discovery-call" } = Astro.props;
---

<div
  class="cal-embed-wrapper gsap-hidden relative flex flex-col rounded-2xl overflow-hidden neu-raised bg-bg-secondary h-[452px] md:h-[572px]"
  data-lenis-prevent
>
  <!-- Click-to-reveal trigger image -->
  <div id="cal-trigger" class="absolute inset-0 z-30 cursor-pointer group">
    <img
      src="/images/cal-placeholder.webp"
      alt="Calendar preview showing available booking times"
      class="w-full h-full object-cover object-top rounded-2xl"
      loading="lazy"
      decoding="async"
    />
    <div
      class="absolute inset-0 flex items-center justify-center bg-black/40 rounded-2xl transition-colors duration-200 group-hover:bg-black/30"
    >
      <button
        id="cal-reveal-btn"
        type="button"
        class="px-6 py-3 bg-accent text-bg font-bold rounded-lg text-base shadow-lg transition-transform duration-200 group-hover:scale-105"
      >
        Book a Discovery Call
      </button>
    </div>
  </div>

  <!-- Loading skeleton (hidden until user clicks) -->
  <div
    id="cal-skeleton"
    class="absolute inset-0 z-20 flex flex-col items-center justify-center bg-bg-secondary rounded-2xl neu-inset"
    style="display: none;"
  >
    <svg
      class="h-6 w-6 animate-spin text-accent"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
    >
      <circle
        class="opacity-25"
        cx="12"
        cy="12"
        r="10"
        stroke="currentColor"
        stroke-width="4"></circle>
      <path
        class="opacity-75"
        fill="currentColor"
        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
    <span class="mt-3 text-sm text-text-muted font-mono"
      >Loading calendar&hellip;</span
    >
  </div>

  <!-- Mobile-only header (event details hidden via Cal.com param on mobile) -->
  <div
    class="sm:hidden flex items-center justify-between px-4 py-3 text-sm text-[#a5a5a5] border-b border-white/5"
  >
    <span class="font-medium text-white">Russ Gardner</span>
    <span>30 min &middot; Pacific Time</span>
  </div>

  <!-- iframe container: cropped viewport into Cal.com, offset to trim top whitespace -->
  <div
    class="cal-iframe-container relative overflow-hidden flex-1 md:h-[572px]"
  >
    <iframe
      id="cal-iframe"
      class="absolute left-0 w-full border-0"
      style="top: -56px; height: calc(100% + 76px); overflow: hidden;"
      scrolling="no"
      sandbox="allow-same-origin allow-scripts allow-forms allow-popups allow-popups-to-escape-sandbox"
      allow="camera; microphone; fullscreen; display-capture; autoplay"
      frameborder="0"
      title="Book a discovery call with Generuss Design"></iframe>
  </div>

  <!-- Mobile-only footer with remaining event details -->
  <div
    class="sm:hidden flex items-center justify-between px-4 py-3 text-sm text-[#a5a5a5] border-t border-white/5"
  >
    <span class="font-medium text-white">Discovery Call</span>
    <span class="flex items-center gap-1.5">
      <svg
        class="w-3.5 h-3.5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><polygon points="23 7 16 12 23 17 23 7"></polygon><rect
          x="1"
          y="5"
          width="15"
          height="14"
          rx="2"
          ry="2"></rect></svg
      >
      Google Meet
    </span>
  </div>
</div>

<!-- Fallback link -->
<p class="text-text-muted text-sm text-center mt-4">
  If the calendar doesn't load, <a
    id="cal-fallback-link"
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="text-accent underline hover:no-underline inline-flex items-center min-h-[44px] py-2"
    >schedule directly here</a
  >.
</p>

<script define:vars={{ url }}>
  (function () {
    var calSlot = document.getElementById("cal-trigger");
    var iframe = document.getElementById("cal-iframe");
    var skeleton = document.getElementById("cal-skeleton");
    var fallback = document.getElementById("cal-fallback-link");

    if (!calSlot || !iframe) return;

    // Forward UTM attribution into the booking. Query string wins; sessionStorage
    // is a fallback so attribution survives in-session navigation. No UTMs present
    // (e.g. the homepage) means this is a no-op and the URL is unchanged.
    function collectUtms() {
      var keys = [
        "utm_source",
        "utm_medium",
        "utm_campaign",
        "utm_term",
        "utm_content",
      ];
      var params = new URLSearchParams(window.location.search);
      var pairs = [];
      keys.forEach(function (k) {
        var v = params.get(k);
        if (!v) {
          try {
            v = sessionStorage.getItem(k);
          } catch (e) {
            v = null;
          }
        }
        if (v) pairs.push(k + "=" + encodeURIComponent(v));
      });
      return pairs;
    }

    function withParams(base, extra) {
      if (!extra.length) return base;
      var sep = base.indexOf("?") === -1 ? "?" : "&";
      return base + sep + extra.join("&");
    }

    var utms = collectUtms();

    // Keep the manual fallback link attributed too.
    if (fallback) fallback.href = withParams(url, utms);

    calSlot.addEventListener("click", function () {
      // Hide trigger, show loading state
      calSlot.style.display = "none";
      if (skeleton) skeleton.style.display = "";

      // Load iframe (mobile trims event-type details; UTMs ride along if present)
      var isMobile = window.innerWidth < 640;
      var extra = utms.slice();
      if (isMobile) extra.unshift("hideEventTypeDetails=true");
      var embedUrl = withParams(url, extra);
      iframe.src = embedUrl;

      iframe.addEventListener("load", function () {
        if (skeleton) skeleton.style.display = "none";
      });

      // Fallback: hide skeleton after 8s even if load doesn't fire
      setTimeout(function () {
        if (skeleton) skeleton.style.display = "none";
      }, 8000);
    });
  })();
</script>
