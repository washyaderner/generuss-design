---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Blog | generuss design",
  ogImage = "/og-default.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link
      rel="preload"
      href="/fonts/inter-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/jetbrains-mono-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <style is:global>
      @import "../styles/global.css";
    </style>

    <style>
      /* Timeline sidebar layout */
      .tl-wrapper {
        display: flex;
        gap: 2rem;
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      /* Sidebar */
      .tl-sidebar {
        position: sticky;
        top: 5rem;
        width: 300px;
        min-width: 300px;
        height: fit-content;
        max-height: calc(100vh - 6rem);
        overflow-y: auto;
        padding: 1.5rem 0;

        /* Hide scrollbar */
        scrollbar-width: none;
        -ms-overflow-style: none;
      }
      .tl-sidebar::-webkit-scrollbar {
        display: none;
      }

      /* Content area */
      .tl-content {
        flex: 1;
        min-width: 0;
        max-width: 65ch;
        padding-bottom: 4rem;
      }

      /* Timeline vertical line */
      .tl-line-track {
        position: absolute;
        left: 20px;
        top: 0;
        width: 2px;
        height: 100%;
        background: var(--color-border);
        border-radius: 1px;
      }
      .tl-line-fill {
        position: absolute;
        left: 20px;
        top: 0;
        width: 2px;
        height: 100%;
        background: var(--color-accent);
        box-shadow:
          0 0 6px var(--color-accent-glow),
          0 0 20px var(--color-accent-dim);
        transform-origin: top center;
        transform: scaleY(0);
        border-radius: 1px;
      }

      /* Timeline container */
      .tl-timeline {
        position: relative;
        padding-left: 50px;
      }

      /* Day node */
      .tl-day {
        position: relative;
        margin-bottom: 1.5rem;
        opacity: 0.4;
        transition: opacity 0.4s ease;
      }
      .tl-day.active {
        opacity: 1;
      }
      .tl-day__circle {
        position: absolute;
        left: -43px;
        top: 2px;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: var(--color-bg-secondary);
        border: 2px solid var(--color-border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-mono);
        font-weight: 700;
        font-size: 0.7rem;
        color: var(--color-text-muted);
        transition: all 0.4s ease;
        z-index: 2;
      }
      .tl-day.active .tl-day__circle {
        border-color: var(--color-accent);
        color: var(--color-accent);
        box-shadow: 0 0 12px var(--color-accent-dim);
      }
      .tl-day__title {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--color-text);
        line-height: 1.2;
      }
      .tl-day__date {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--color-text-muted);
        margin-top: 0.15rem;
      }

      /* Milestone items */
      .tl-milestone {
        position: relative;
        padding: 0.5rem 0;
        padding-left: 0;
        margin-bottom: 0.25rem;
        opacity: 0.3;
        transition: opacity 0.4s ease;
      }
      .tl-milestone.active {
        opacity: 1;
      }
      .tl-milestone__dot {
        position: absolute;
        left: -33px;
        top: 0.75rem;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--color-border);
        transition: all 0.4s ease;
      }
      .tl-milestone.active .tl-milestone__dot {
        background: var(--color-accent);
        box-shadow: 0 0 8px var(--color-accent-glow);
      }
      .tl-milestone__title {
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--color-text-muted);
        line-height: 1.3;
        transition: color 0.4s ease;
      }
      .tl-milestone.active .tl-milestone__title {
        color: var(--color-text);
      }

      /* Mobile: hide sidebar, show progress bar */
      @media (max-width: 1024px) {
        .tl-wrapper {
          flex-direction: column;
          padding: 0 1.5rem;
        }
        .tl-sidebar {
          display: none;
        }
        .tl-content {
          max-width: 100%;
        }
        .tl-mobile-progress {
          display: block;
        }
      }

      @media (min-width: 1025px) {
        .tl-mobile-progress {
          display: none;
        }
      }

      /* Mobile progress bar */
      .tl-mobile-progress {
        position: fixed;
        top: 3.5rem;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--color-border);
        z-index: 40;
      }
      .tl-mobile-progress__fill {
        height: 100%;
        background: var(--color-accent);
        box-shadow: 0 0 6px var(--color-accent-glow);
        width: 0%;
        transition: width 0.1s linear;
      }
    </style>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[10000] focus:rounded-lg focus:bg-accent focus:px-4 focus:py-2 focus:text-[#0C0C0C] focus:font-semibold focus:outline-none"
    >
      Skip to content
    </a>

    <Nav alwaysVisible={true} />

    <!-- Mobile progress bar -->
    <div class="tl-mobile-progress">
      <div class="tl-mobile-progress__fill" id="mobile-progress"></div>
    </div>

    <main id="main-content" class="pt-24 pb-16">
      <div class="tl-wrapper">
        <!-- Timeline sidebar -->
        <aside class="tl-sidebar" id="timeline-sidebar">
          <div class="tl-timeline">
            <div class="tl-line-track"></div>
            <div class="tl-line-fill" id="tl-line-fill"></div>

            <!-- Day 1 -->
            <div class="tl-day" data-day="1">
              <div class="tl-day__circle">01</div>
              <div class="tl-day__title">Foundation</div>
              <div class="tl-day__date">Feb 15</div>
            </div>
            <div class="tl-milestone" data-day="1">
              <div class="tl-milestone__dot"></div>
              <div class="tl-milestone__title">Full scaffold</div>
            </div>
            <div class="tl-milestone" data-day="1">
              <div class="tl-milestone__dot"></div>
              <div class="tl-milestone__title">Config sprint</div>
            </div>
            <div class="tl-milestone" data-day="1">
              <div class="tl-milestone__dot"></div>
              <div class="tl-milestone__title">QA infrastructure</div>
            </div>
            <div class="tl-milestone" data-day="1">
              <div class="tl-milestone__dot"></div>
              <div class="tl-milestone__title">First deploy</div>
            </div>

            <!-- Day 2 -->
            <div class="tl-day" data-day="2" style="margin-top: 1.5rem;">
              <div class="tl-day__circle">02</div>
              <div class="tl-day__title">Craft</div>
              <div class="tl-day__date">Feb 16</div>
            </div>
            <div class="tl-milestone" data-day="2">
              <div class="tl-milestone__dot"></div>
              <div class="tl-milestone__title">Critical QA pass</div>
            </div>
            <div class="tl-milestone" data-day="2">
              <div class="tl-milestone__dot"></div>
              <div class="tl-milestone__title">Design overhaul</div>
            </div>
            <div class="tl-milestone" data-day="2">
              <div class="tl-milestone__dot"></div>
              <div class="tl-milestone__title">Animation push</div>
            </div>
            <div class="tl-milestone" data-day="2">
              <div class="tl-milestone__dot"></div>
              <div class="tl-milestone__title">Major restructure</div>
            </div>

            <!-- Day 3 -->
            <div class="tl-day" data-day="3" style="margin-top: 1.5rem;">
              <div class="tl-day__circle">03</div>
              <div class="tl-day__title">Ship</div>
              <div class="tl-day__date">Feb 17</div>
            </div>
            <div class="tl-milestone" data-day="3">
              <div class="tl-milestone__dot"></div>
              <div class="tl-milestone__title">Rapid-fire fixes</div>
            </div>
            <div class="tl-milestone" data-day="3">
              <div class="tl-milestone__dot"></div>
              <div class="tl-milestone__title">Cal.com rebuild</div>
            </div>
            <div class="tl-milestone" data-day="3">
              <div class="tl-milestone__dot"></div>
              <div class="tl-milestone__title">Final polish</div>
            </div>
          </div>
        </aside>

        <!-- Blog content -->
        <div class="tl-content">
          <a
            href="/blog"
            class="text-accent hover:underline text-sm mb-8 inline-block"
            >&larr; Back to Blog</a
          >

          <div class="mb-6">
            <slot name="meta" />
          </div>

          <article class="prose prose-invert max-w-none" id="blog-article">
            <slot />
          </article>
        </div>
      </div>
    </main>

    <Footer />

    <!-- GSAP for timeline sync -->
    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      // Respect reduced motion
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const lineFill = document.getElementById("tl-line-fill");
        const article = document.getElementById("blog-article");
        const mobileProgress = document.getElementById("mobile-progress");

        if (article && lineFill) {
          // Overall scroll progress drives the timeline line
          ScrollTrigger.create({
            trigger: article,
            start: "top 20%",
            end: "bottom 80%",
            scrub: 0.3,
            onUpdate: (self) => {
              const progress = self.progress;
              gsap.set(lineFill, { scaleY: progress });

              // Mobile progress bar
              if (mobileProgress) {
                mobileProgress.style.width = `${progress * 100}%`;
              }
            },
          });

          // Day section activation - look for H2s with "day" in their ID or text
          const headings = article.querySelectorAll("h2");
          const dayNodes = document.querySelectorAll(".tl-day");
          const milestones = document.querySelectorAll(".tl-milestone");

          // Map headings to day numbers based on order
          // First H2 group = day 1, etc.
          let currentDayIndex = 0;
          const dayHeadings: { el: HTMLElement; day: number }[] = [];

          headings.forEach((h2) => {
            const text = h2.textContent?.toLowerCase() || "";
            if (text.includes("day 1") || text.includes("foundation")) {
              currentDayIndex = 1;
            } else if (text.includes("day 2") || text.includes("marathon")) {
              currentDayIndex = 2;
            } else if (text.includes("day 3") || text.includes("ship")) {
              currentDayIndex = 3;
            }
            if (currentDayIndex > 0) {
              dayHeadings.push({ el: h2 as HTMLElement, day: currentDayIndex });
            }
          });

          // Create ScrollTriggers for each day heading
          dayHeadings.forEach(({ el, day }) => {
            ScrollTrigger.create({
              trigger: el,
              start: "top 60%",
              end: "bottom 20%",
              onEnter: () => activateDay(day),
              onEnterBack: () => activateDay(day),
            });
          });

          function activateDay(day: number) {
            // Activate matching day nodes
            dayNodes.forEach((node) => {
              const nodeDayAttr = node.getAttribute("data-day");
              if (nodeDayAttr) {
                const nodeDay = parseInt(nodeDayAttr);
                node.classList.toggle("active", nodeDay <= day);
              }
            });

            // Activate milestones for current and previous days
            milestones.forEach((ms) => {
              const msDayAttr = ms.getAttribute("data-day");
              if (msDayAttr) {
                const msDay = parseInt(msDayAttr);
                ms.classList.toggle("active", msDay <= day);
              }
            });
          }

          // Activate day 1 on load if article is visible
          if (article.getBoundingClientRect().top < window.innerHeight) {
            activateDay(1);
          }
        }
      }
    </script>
  </body>
</html>
