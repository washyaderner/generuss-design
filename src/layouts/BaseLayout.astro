---
import { siteGraph } from "../lib/schema";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Custom websites for service businesses and founders who outgrew templates. No bloat. Designed to convert.",
  ogImage = "/og-default.png",
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Fonts -->
    <link
      rel="preload"
      href="/fonts/inter-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/jetbrains-mono-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": siteGraph(Astro.site!),
      })}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body class="paper-grain">
    <a
      href="#main-content"
      class="sr-only invisible focus:visible focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[10000] focus:rounded-lg focus:bg-accent focus:px-4 focus:py-2 focus:text-paper focus:font-semibold focus:outline-none focus:min-h-[44px] focus:inline-flex focus:items-center"
    >
      Skip to content
    </a>

    <!-- Sheet registration marks -->
    <span
      class="reg-mark hidden sm:block"
      style="top: 76px; left: 14px;"
      aria-hidden="true"></span>
    <span
      class="reg-mark hidden sm:block"
      style="top: 76px; right: 14px;"
      aria-hidden="true"></span>
    <span
      class="reg-mark hidden sm:block"
      style="bottom: 14px; left: 14px;"
      aria-hidden="true"></span>
    <span
      class="reg-mark hidden sm:block"
      style="bottom: 14px; right: 14px;"
      aria-hidden="true"></span>

    <slot />

    <script>
      // Reveal choreography: .rise/.cascade-card gain .visible, rules and
      // dimension lines gain .drawn, when they enter the viewport.
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            e.target.classList.add(
              e.target.classList.contains("rule-draw") ||
                e.target.classList.contains("dim-h")
                ? "drawn"
                : "visible",
            );
            io.unobserve(e.target);
          }
        },
        { threshold: 0.18, rootMargin: "0px 0px -40px 0px" },
      );
      document
        .querySelectorAll(".rise, .cascade-card, .rule-draw, .dim-h")
        .forEach((el) => io.observe(el));
    </script>
  </body>
</html>
