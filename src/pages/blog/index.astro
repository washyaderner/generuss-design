---
import BlogLayout from "../../layouts/BlogLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getAllPosts } from "../../lib/blog";

const posts = await getAllPosts();

const POSTS_PER_PAGE = 10;
const page = Number(Astro.url.searchParams.get("page") || "1");
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
const paginatedPosts = posts.slice(
  (page - 1) * POSTS_PER_PAGE,
  page * POSTS_PER_PAGE,
);
---

<BlogLayout
  title="Web Design + AI Build Logs | generuss design"
  description="Build logs and essays on web design, AI automation, and sales strategy from real shipped projects. How the sites get made and what they teach."
  wide={true}
  ogType="website"
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "CollectionPage",
          "@id": new URL("/blog/", Astro.site).toString(),
          name: "Web Design + AI Build Logs",
          url: new URL("/blog/", Astro.site).toString(),
          isPartOf: { "@id": `${Astro.site}#website` },
        },
        {
          "@type": "BreadcrumbList",
          itemListElement: [
            {
              "@type": "ListItem",
              position: 1,
              name: "Home",
              item: String(Astro.site),
            },
            {
              "@type": "ListItem",
              position: 2,
              name: "Blog",
              item: new URL("/blog/", Astro.site).toString(),
            },
          ],
        },
      ],
    })}
  />
  <a href="/" class="text-accent hover:underline text-sm mb-8 inline-block"
    >&larr; Back to Home</a
  >

  <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-8">
    Blog
  </h1>

  {
    posts.length === 0 && (
      <div class="rounded-xl bg-bg-secondary p-6 text-text-muted text-center">
        <p>No posts yet. Check back soon.</p>
      </div>
    )
  }

  {
    paginatedPosts.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        {paginatedPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    )
  }

  {
    totalPages > 1 && (
      <div class="flex justify-between items-center mt-8">
        {page > 1 ? (
          <a
            href={`/blog?page=${page - 1}`}
            class="text-accent hover:underline"
          >
            &larr; Newer Posts
          </a>
        ) : (
          <span />
        )}
        {page < totalPages ? (
          <a
            href={`/blog?page=${page + 1}`}
            class="text-accent hover:underline"
          >
            Older Posts &rarr;
          </a>
        ) : (
          <span />
        )}
      </div>
    )
  }
</BlogLayout>
