---
import BlogLayout from "../../layouts/BlogLayout.astro";
import TimelineBlogLayout from "../../layouts/TimelineBlogLayout.astro";
import BlogMeta from "../../components/BlogMeta.astro";
import {
  getAllPosts,
  getPostBySlug,
  getReadingTime,
  renderPost,
} from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const result = await getPostBySlug(slug);

if (!result) {
  return Astro.redirect("/blog");
}

const { post, entry } = result;
const { Content } = await renderPost(entry);
const readingTime = getReadingTime(entry.body || "");
const useTimeline = post.layout === "timeline";

const title = `${post.title} | generuss design`;
const description = post.excerpt;
---

{
  useTimeline && (
    <TimelineBlogLayout
      title={title}
      description={description}
      ogImage={post.featuredImage}
    >
      <Fragment slot="meta">
        <BlogMeta
          date={post.publishDate}
          tags={post.tags}
          readingTime={readingTime}
        />
      </Fragment>
      <Content />
    </TimelineBlogLayout>
  )
}

{
  !useTimeline && (
    <BlogLayout
      title={title}
      description={description}
      ogImage={post.featuredImage}
    >
      <script
        type="application/ld+json"
        set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "Article",
          headline: post.title,
          description: post.excerpt,
          image: post.featuredImage,
          datePublished: post.publishDate,
          author: {
            "@type": "Person",
            name: "Russ",
            url: "https://generussdesign.com",
          },
          publisher: {
            "@type": "Organization",
            name: "generuss design",
            url: "https://generussdesign.com",
          },
        })}
      />

      <a
        href="/blog"
        class="text-accent hover:underline text-sm mb-8 inline-block"
      >
        &larr; Back to Blog
      </a>

      {post.featuredImage !== "/images/placeholder.svg" && (
        <div class="neu-raised rounded-2xl overflow-hidden mb-8">
          <img
            src={post.featuredImage}
            alt={post.title}
            width={1200}
            height={630}
            class="w-full"
          />
        </div>
      )}

      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        {post.title}
      </h1>

      <div class="mb-8">
        <BlogMeta
          date={post.publishDate}
          tags={post.tags}
          readingTime={readingTime}
        />
      </div>

      <article class="prose prose-invert max-w-none">
        <Content />
      </article>
    </BlogLayout>
  )
}
