---
import BlogLayout from "../../layouts/BlogLayout.astro";
import TimelineBlogLayout from "../../layouts/TimelineBlogLayout.astro";
import BlogMeta from "../../components/BlogMeta.astro";
import {
  getAllPosts,
  getPostBySlug,
  getReadingTime,
  renderPost,
} from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const result = await getPostBySlug(slug);

if (!result) {
  return Astro.redirect("/blog");
}

const { post, entry } = result;
const { Content } = await renderPost(entry);
const readingTime = getReadingTime(entry.body || "");
const useTimeline = post.layout === "timeline";

// seoTitle/metaDescription override the SERP surfaces only; on-page headline
// and card excerpt keep the full editorial voice.
const title = `${post.seoTitle ?? post.title} | generuss design`;
const description = post.metaDescription ?? post.excerpt;

const articleSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: post.title,
      description,
      image: post.featuredImage
        ? new URL(post.featuredImage, Astro.site).toString()
        : undefined,
      datePublished: post.publishDate,
      dateModified: post.updatedDate ?? post.publishDate,
      mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
      author: {
        "@type": "Person",
        "@id": `${Astro.site}#person`,
        name: "Russ Gardner",
        url: String(Astro.site),
      },
      publisher: {
        "@type": "Organization",
        "@id": `${Astro.site}#org`,
        name: "generuss design",
        url: String(Astro.site),
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: String(Astro.site),
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Blog",
          item: new URL("/blog/", Astro.site).toString(),
        },
        {
          "@type": "ListItem",
          position: 3,
          name: post.title,
          item: new URL(Astro.url.pathname, Astro.site).toString(),
        },
      ],
    },
  ],
};
---

{
  useTimeline && (
    <TimelineBlogLayout
      title={title}
      description={description}
      ogImage={post.featuredImage}
      timeline={post.timeline || []}
    >
      <script
        type="application/ld+json"
        set:html={JSON.stringify(articleSchema)}
      />
      <Fragment slot="meta">
        <BlogMeta
          date={post.publishDate}
          tags={post.tags}
          readingTime={readingTime}
        />
      </Fragment>
      <Content />
    </TimelineBlogLayout>
  )
}

{
  !useTimeline && (
    <BlogLayout
      title={title}
      description={description}
      ogImage={post.featuredImage}
    >
      <script
        type="application/ld+json"
        set:html={JSON.stringify(articleSchema)}
      />

      <a
        href="/blog"
        class="text-accent hover:underline text-sm mb-8 inline-block"
      >
        &larr; Back to Blog
      </a>

      {post.featuredImage && (
        <div class="neu-raised rounded-2xl overflow-hidden mb-8">
          <img
            src={post.featuredImage}
            alt={post.title}
            width={1200}
            height={630}
            class="w-full"
          />
        </div>
      )}

      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        {post.title}
      </h1>

      <div class="mb-8">
        <BlogMeta
          date={post.publishDate}
          tags={post.tags}
          readingTime={readingTime}
        />
      </div>

      <article class="prose prose-invert max-w-none">
        <Content />
      </article>
    </BlogLayout>
  )
}
