---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID || "xgolkboq";
---

<BaseLayout title="generuss design | Web Design & AI Automation">
  <Nav />

  <main id="main-content">
    <!-- S1: Hero -->
    <section
      id="hero"
      class="relative flex min-h-screen items-center overflow-hidden px-8 sm:px-12 lg:px-20"
    >
      <div class="relative z-10">
        <h1>
          <span
            class="hero-headline gsap-hidden block text-[3.9rem] sm:text-[4.875rem] md:text-[5.85rem] lg:text-[7.8rem] font-black tracking-tight leading-[0.95]"
          >
            BUILDING GORGEOUS WEBSITES
          </span>
          <span
            class="hero-headline gsap-hidden block text-[3.9rem] sm:text-[4.875rem] md:text-[5.85rem] lg:text-[7.8rem] font-black tracking-tight leading-[0.95] text-accent glow-text mt-2"
          >
            THAT CONVERT
          </span>
          <span
            class="hero-headline gsap-hidden block text-[1.625rem] sm:text-[1.95rem] md:text-[2.4375rem] lg:text-[2.925rem] font-semibold tracking-wide text-text-muted mt-4"
          >
            FLAWLESS BY DESIGN.
          </span>
        </h1>
        <p
          class="hero-sub gsap-hidden mt-6 max-w-2xl text-[1.46rem] sm:text-[1.625rem] md:text-[1.95rem] text-text-muted"
        >
          Design that converts visitors into customers.<br />
          Built fast. Looks sharp. No bloat.
        </p>
        <a
          href="#contact"
          class="hero-cta gsap-hidden mt-8 inline-block rounded-full bg-accent px-8 py-3 text-base font-semibold text-[#0C0C0C] transition-shadow duration-200 hover:shadow-[0_0_30px_var(--color-accent-mid)]"
        >
          Let's Build Yours &rarr;
        </a>
      </div>

      <!-- Geometric shapes -->
      <div
        class="hero-shape gsap-hidden absolute top-[15%] right-[10%] h-32 w-32 sm:h-48 sm:w-48 opacity-[0.04]"
        style="background: var(--color-accent); clip-path: polygon(50% 0%, 100% 100%, 0% 100%);"
      >
      </div>
      <div
        class="hero-shape gsap-hidden absolute bottom-[20%] right-[25%] h-24 w-40 sm:h-36 sm:w-56 opacity-[0.03]"
        style="background: var(--color-accent); clip-path: polygon(25% 0%, 100% 0%, 75% 100%, 0% 100%);"
      >
      </div>
      <div
        class="hero-shape gsap-hidden absolute top-[40%] left-[60%] h-28 w-28 sm:h-40 sm:w-40 opacity-[0.04]"
        style="background: var(--color-accent); clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%);"
      >
      </div>
      <div
        class="hero-shape gsap-hidden absolute bottom-[30%] left-[5%] h-20 w-20 sm:h-32 sm:w-32 opacity-[0.03] hidden sm:block"
        style="background: var(--color-accent); clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);"
      >
      </div>
      <div
        class="hero-shape gsap-hidden absolute top-[10%] left-[30%] h-16 w-16 sm:h-24 sm:w-24 opacity-[0.05] hidden sm:block"
        style="background: var(--color-accent); clip-path: polygon(50% 0%, 100% 100%, 0% 100%);"
      >
      </div>

      <!-- Scroll indicator -->
      <div
        class="scroll-indicator gsap-hidden absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2"
      >
        <span class="text-xs text-text-muted font-mono tracking-wider"
          >SCROLL</span
        >
        <div class="h-8 w-px bg-text-muted/50 animate-pulse"></div>
      </div>
    </section>

    <!-- S2: Problem/Solution -->
    <section id="problem-solution" class="relative">
      <!-- Pinned Problem/Solution Grid -->
      <div class="ps-pin relative min-h-screen">
        <div
          class="ps-grid flex flex-col justify-center md:min-h-screen px-8 sm:px-12 lg:px-20 pt-10 sm:pt-14 pb-8 sm:pb-12 gap-4 sm:gap-6 md:gap-8 bg-bg-secondary"
        >
          <!-- Section Intro (inside pinned area) -->
          <div
            class="ps-intro grid place-items-center pb-4 sm:pb-6 overflow-hidden"
          >
            <!-- Joke (on top, will shatter) -->
            <p
              class="ps-joke gsap-hidden text-xl sm:text-2xl md:text-4xl lg:text-5xl font-black text-center italic text-text-muted/80 col-start-1 row-start-1 z-10"
              aria-hidden="true"
            >
              Webster's Dictionary Defines a Good Site As...
            </p>
            <!-- Real heading (underneath) -->
            <h2
              class="ps-real gsap-hidden text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-center col-start-1 row-start-1"
            >
              generuss sites <span class="text-accent glow-text">convert,</span> and
              <span class="text-accent">look good doing it.</span>
            </h2>
          </div>
          <!-- Pair 1 -->
          <div
            class="ps-row grid grid-cols-1 md:grid-cols-2 gap-2 sm:gap-3 md:gap-8 items-start"
          >
            <div
              class="ps-problem opacity-50 neu-inset rounded-2xl p-4 sm:p-6 md:p-8"
            >
              <h3 class="text-lg sm:text-xl font-bold text-text mb-2">
                Cookie-Cutter Stacks
              </h3>
              <p class="text-sm sm:text-base text-text-muted leading-relaxed">
                Most agencies pick their tools before they hear your goals. Same
                framework, same template system, same stack &mdash; whether
                you're a therapist or a SaaS company.
              </p>
            </div>
            <div
              class="ps-solution gsap-hidden neu-raised rounded-2xl p-4 sm:p-6 md:p-8 bg-bg transition-shadow duration-300 hover:shadow-[8px_8px_20px_rgba(0,0,0,0.8),-4px_-4px_12px_rgba(255,255,255,0.06),0_0_30px_var(--color-accent-dim)]"
            >
              <h3 class="text-lg sm:text-xl font-bold text-accent mb-2">
                Custom Stack Audit
              </h3>
              <p class="text-sm sm:text-base text-text-muted leading-relaxed">
                Every project starts with a tech stack audit, matching the tools
                to your business, not the other way around.
              </p>
            </div>
          </div>

          <!-- Pair 2 -->
          <div
            class="ps-row grid grid-cols-1 md:grid-cols-2 gap-2 sm:gap-3 md:gap-8 items-start"
          >
            <div
              class="ps-problem opacity-50 neu-inset rounded-2xl p-4 sm:p-6 md:p-8"
            >
              <h3 class="text-lg sm:text-xl font-bold text-text mb-2">
                Performance
              </h3>
              <p class="text-sm sm:text-base text-text-muted leading-relaxed">
                Most agency sites score 40-60 on Lighthouse. Slow loads, bloated
                bundles, third-party script soup.
              </p>
            </div>
            <div
              class="ps-solution gsap-hidden neu-raised rounded-2xl p-4 sm:p-6 md:p-8 bg-bg transition-shadow duration-300 hover:shadow-[8px_8px_20px_rgba(0,0,0,0.8),-4px_-4px_12px_rgba(255,255,255,0.06),0_0_30px_var(--color-accent-dim)]"
            >
              <h3 class="text-lg sm:text-xl font-bold text-accent mb-2">
                Lighthouse 90%+
              </h3>
              <p class="text-sm sm:text-base text-text-muted leading-relaxed">
                Every Generuss build targets Lighthouse 90%+. Static-first
                architecture, zero unnecessary JavaScript.
              </p>
            </div>
          </div>

          <!-- Pair 3 -->
          <div
            class="ps-row grid grid-cols-1 md:grid-cols-2 gap-2 sm:gap-3 md:gap-8 items-start"
          >
            <div
              class="ps-problem opacity-50 neu-inset rounded-2xl p-4 sm:p-6 md:p-8"
            >
              <h3 class="text-lg sm:text-xl font-bold text-text mb-2">
                Conversion
              </h3>
              <p class="text-sm sm:text-base text-text-muted leading-relaxed">
                Your site looks fine. But "fine" doesn't convert. Most sites sit
                at a 2-3% conversion rate because nobody designed the page to
                guide people toward action.
              </p>
            </div>
            <div
              class="ps-solution gsap-hidden neu-raised rounded-2xl p-4 sm:p-6 md:p-8 bg-bg transition-shadow duration-300 hover:shadow-[8px_8px_20px_rgba(0,0,0,0.8),-4px_-4px_12px_rgba(255,255,255,0.06),0_0_30px_var(--color-accent-dim)]"
            >
              <h3 class="text-lg sm:text-xl font-bold text-accent mb-2">
                Conversion-Engineered
              </h3>
              <p class="text-sm sm:text-base text-text-muted leading-relaxed">
                Every element on the page has a job. CTAs that are impossible to
                miss, forms that don't make people quit, and a layout that
                funnels attention exactly where it needs to go.
              </p>
            </div>
          </div>

          <!-- Pair 4 -->
          <div
            class="ps-row grid grid-cols-1 md:grid-cols-2 gap-2 sm:gap-3 md:gap-8 items-start"
          >
            <div
              class="ps-problem opacity-50 neu-inset rounded-2xl p-4 sm:p-6 md:p-8"
            >
              <h3 class="text-lg sm:text-xl font-bold text-text mb-2">
                Post-Launch Abandonment
              </h3>
              <p class="text-sm sm:text-base text-text-muted leading-relaxed">
                The site launches, the invoice clears, and your agency ghosts.
                Something breaks six months later and you're Googling how to fix
                your own website.
              </p>
            </div>
            <div
              class="ps-solution gsap-hidden neu-raised rounded-2xl p-4 sm:p-6 md:p-8 bg-bg transition-shadow duration-300 hover:shadow-[8px_8px_20px_rgba(0,0,0,0.8),-4px_-4px_12px_rgba(255,255,255,0.06),0_0_30px_var(--color-accent-dim)]"
            >
              <h3 class="text-lg sm:text-xl font-bold text-accent mb-2">
                Ongoing Support
              </h3>
              <p class="text-sm sm:text-base text-text-muted leading-relaxed">
                Every build ships with documentation, a walkthrough, and a
                direct line. No ticket queues, no support tiers &mdash; just a
                real person who built the thing.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- S3: Design Principles -->
    <section id="principles" class="bg-bg-secondary">
      <!-- Pinned Principles -->
      <div
        class="principles-pin relative min-h-screen flex flex-col justify-center px-8 sm:px-12 lg:px-20"
      >
        <!-- Section Header -->
        <h2
          class="principles-heading gsap-hidden text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black pt-8 sm:pt-12 pb-6 sm:pb-8"
        >
          What Makes a Website <span class="text-accent">Actually Good?</span>
        </h2>

        <!-- Subheading -->
        <div class="overflow-hidden pb-6 sm:pb-8">
          <p
            class="principles-subheading gsap-hidden text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-right"
          >
            Most websites look fine.<br />
            The problem is "fine" doesn't get you <span class="text-accent"
              >customers.</span
            >
          </p>
        </div>

        <!-- 6 Principles Grid -->
        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 pb-8 sm:pb-12 max-w-5xl mx-auto"
        >
          <div
            class="principle-card gsap-hidden neu-raised rounded-2xl p-6 md:p-8"
          >
            <svg
              class="mb-4"
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#00ffef66"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"
              ></path>
            </svg>
            <h3 class="text-xl font-bold text-white mb-1">Speed</h3>
            <p class="font-mono text-xs text-accent mb-3">
              53% leave if it takes 3+ seconds
            </p>
            <p class="text-sm text-text-muted leading-relaxed">
              Your site loads before they can blink. Performance isn't a feature
              &mdash; it's the foundation.
            </p>
          </div>

          <div
            class="principle-card gsap-hidden neu-raised rounded-2xl p-6 md:p-8"
          >
            <svg
              class="mb-4"
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#00ffef66"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect>
              <path d="M12 18h.01"></path>
            </svg>
            <h3 class="text-xl font-bold text-white mb-1">Mobile-First</h3>
            <p class="font-mono text-xs text-accent mb-3">
              63%+ of web traffic is mobile
            </p>
            <p class="text-sm text-text-muted leading-relaxed">
              Designed for thumbs first, then scaled up. Not the other way
              around.
            </p>
          </div>

          <div
            class="principle-card gsap-hidden neu-raised rounded-2xl p-6 md:p-8"
          >
            <svg
              class="mb-4"
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#00ffef66"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"
              ></path>
              <path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"></path>
              <path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"></path>
            </svg>
            <h3 class="text-xl font-bold text-white mb-1">Clear Hierarchy</h3>
            <p class="font-mono text-xs text-accent mb-3">
              Users scan, they don't read
            </p>
            <p class="text-sm text-text-muted leading-relaxed">
              Every element has a job. Nothing on the page is decoration &mdash;
              it's all working.
            </p>
          </div>

          <div
            class="principle-card gsap-hidden neu-raised rounded-2xl p-6 md:p-8"
          >
            <svg
              class="mb-4"
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#00ffef66"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
            <h3 class="text-xl font-bold text-white mb-1">SEO Built In</h3>
            <p class="font-mono text-xs text-accent mb-3">
              68% of online experiences start with search
            </p>
            <p class="text-sm text-text-muted leading-relaxed">
              Structured data, meta tags, fast loads, clean code. Google finds
              you, not the other way around.
            </p>
          </div>

          <div
            class="principle-card gsap-hidden neu-raised rounded-2xl p-6 md:p-8"
          >
            <svg
              class="mb-4"
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#00ffef66"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"></path>
              <path d="M12 18V6"></path>
            </svg>
            <h3 class="text-xl font-bold text-white mb-1">Conversion Focus</h3>
            <p class="font-mono text-xs text-accent mb-3">
              Average site converts at 2-3%
            </p>
            <p class="text-sm text-text-muted leading-relaxed">
              Good design guides people to act. CTAs that work, forms that don't
              suck, zero friction.
            </p>
          </div>

          <div
            class="principle-card gsap-hidden neu-raised rounded-2xl p-6 md:p-8"
          >
            <svg
              class="mb-4"
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#00ffef66"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="16" cy="4" r="1"></circle>
              <path d="m18 19 1-7-6 1"></path>
              <path d="m5 8 3-3 5.5 3-2.36 3.5"></path>
              <path d="m4.24 14.5a5 5 0 0 0 6.88 6"></path>
              <path d="M13.76 17.5a5 5 0 0 0-6.88-6"></path>
            </svg>
            <h3 class="text-xl font-bold text-white mb-1">Accessibility</h3>
            <p class="font-mono text-xs text-accent mb-3">
              1 in 4 adults has a disability
            </p>
            <p class="text-sm text-text-muted leading-relaxed">
              Inclusive by default. More users, fewer lawsuits, better
              experience for everyone.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- S4: Services -->
    <section
      id="services"
      class="bg-bg-secondary px-8 sm:px-12 lg:px-20 py-(--spacing-section)"
    >
      <h2
        class="services-heading gsap-hidden text-3xl sm:text-4xl md:text-5xl font-bold text-center mb-12 sm:mb-16"
      >
        What I <span class="text-accent">Build.</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Card 1 -->
        <div
          class="service-card gsap-hidden neu-raised rounded-2xl p-8 sm:p-10 transition-shadow duration-300 hover:shadow-[8px_8px_20px_rgba(0,0,0,0.8),-4px_-4px_12px_rgba(255,255,255,0.06),0_0_30px_var(--color-accent-dim)]"
        >
          <h3 class="text-2xl font-bold text-white mb-3">
            Web Design & Development
          </h3>
          <p class="text-text-muted mb-6">
            Fast, clean sites that convert &mdash; built custom for your
            business.
          </p>
          <ul class="space-y-3 text-sm text-text-muted">
            <li class="flex items-start gap-3">
              <span class="text-accent mt-0.5">&#10003;</span>
              <span>Discovery call + tech stack audit</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-0.5">&#10003;</span>
              <span>Custom design and development (no templates)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-0.5">&#10003;</span>
              <span>Mobile-first, Lighthouse 90%+ builds</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-0.5">&#10003;</span>
              <span
                >Static architecture &mdash; no CMS vulnerabilities, no plugin
                rot, no surprise security patches</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-0.5">&#10003;</span>
              <span>Launch documentation + walkthrough</span>
            </li>
          </ul>
        </div>

        <!-- Card 2 -->
        <div
          class="service-card gsap-hidden neu-raised rounded-2xl p-8 sm:p-10 transition-shadow duration-300 hover:shadow-[8px_8px_20px_rgba(0,0,0,0.8),-4px_-4px_12px_rgba(255,255,255,0.06),0_0_30px_var(--color-accent-dim)]"
        >
          <h3 class="text-2xl font-bold text-white mb-3">
            AI Automation Consulting
          </h3>
          <p class="text-text-muted mb-6">
            Workflows that run themselves so you can focus on the work that
            matters.
          </p>
          <ul class="space-y-3 text-sm text-text-muted">
            <li class="flex items-start gap-3">
              <span class="text-accent mt-0.5">&#10003;</span>
              <span>Process audit and automation mapping</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-0.5">&#10003;</span>
              <span
                >Custom automation builds (n8n, Make.com, API integrations)</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-0.5">&#10003;</span>
              <span>AI tool selection and implementation</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-0.5">&#10003;</span>
              <span>Documentation + handoff</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Growth Partner Block -->
      <div
        class="growth-partner gsap-hidden max-w-2xl mx-auto mt-16 text-center"
      >
        <p class="text-lg text-text-muted leading-relaxed">
          Consider me your growth partner &mdash; your site doesn't stop at
          launch. Need a lead form that triggers an email sequence? A booking
          flow that syncs to your CRM? I build the site and the systems behind
          it. One person, one bill, zero handoff chaos.
        </p>
        <p class="text-lg text-text-muted leading-relaxed mt-4">
          If your business needs go deeper than the site itself &mdash; workflow
          automation, AI tool integration, entire processes that run themselves
          &mdash; that's not a referral to someone else. That's the other half
          of what I do.
        </p>
      </div>

      <!-- Section CTA -->
      <div class="services-cta gsap-hidden text-center mt-12">
        <a
          href="#contact"
          class="inline-block rounded-full bg-accent px-10 py-4 text-lg font-semibold text-[#0C0C0C] transition-shadow duration-200 hover:shadow-[0_0_30px_var(--color-accent-mid)]"
        >
          Let's figure out <span class="font-bold">what you need</span> &rarr;
        </a>
      </div>
    </section>

    <!-- S5: Portfolio -->
    <section
      id="portfolio"
      class="px-8 sm:px-12 lg:px-20 py-(--spacing-section)"
    >
      <h2
        class="portfolio-heading gsap-hidden text-3xl sm:text-4xl md:text-5xl font-bold text-center mb-3"
      >
        What I've <span class="text-accent">Built.</span>
      </h2>
      <p
        class="portfolio-subline gsap-hidden text-text-muted text-lg text-center mb-12 sm:mb-16"
      >
        Click any project to see it up close.
      </p>

      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto"
      >
        <!-- Project 1: Crystal Seed Tarot -->
        <div
          class="portfolio-card gsap-hidden group cursor-pointer neu-raised rounded-2xl overflow-hidden transition-shadow duration-300 hover:shadow-[8px_8px_20px_rgba(0,0,0,0.8),-4px_-4px_12px_rgba(255,255,255,0.06),0_0_30px_var(--color-accent-dim)]"
          data-project="crystal-seed-tarot"
          data-title="Crystal Seed Tarot"
          data-url="https://crystalseedtarot.com"
