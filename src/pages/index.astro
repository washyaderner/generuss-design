    <script>
      // Contact form handling
      const form = document.getElementById("contact-form") as HTMLFormElement;
      const successMsg = document.getElementById("form-success");
      const submitBtn = form?.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement;
      const submitText = submitBtn?.textContent;

      form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(form);

        submitBtn.disabled = true;
        submitBtn.textContent = "Sending...";
        submitBtn.classList.add("opacity-50", "cursor-not-allowed");

        try {
          const res = await fetch(form.action, {
            method: "POST",
            body: data,
            headers: { Accept: "application/json" },
          });

          if (res.ok) {
            form.classList.add("hidden");
            successMsg?.classList.remove("hidden");
          } else {
            submitBtn.disabled = false;
            submitBtn.textContent = submitText ?? "Send Message →";
            submitBtn.classList.remove("opacity-50", "cursor-not-allowed");
            alert("Something went wrong. Please try again.");
          }
        } catch {
          submitBtn.disabled = false;
          submitBtn.textContent = submitText ?? "Send Message →";
          submitBtn.classList.remove("opacity-50", "cursor-not-allowed");
          alert("Network error. Please try again.");
        }
      });

      // Lead-magnet form (smaller form, single email field)
      const leadForm = document.getElementById(
        "lead-magnet-form",
      ) as HTMLFormElement;
      const leadSuccess = document.getElementById("lead-magnet-success");
      const leadBtn = leadForm?.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement;
      const leadBtnText = leadBtn?.textContent;

      leadForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(leadForm);

        leadBtn.disabled = true;
        leadBtn.textContent = "Opening...";
        leadBtn.classList.add("opacity-60");

        try {
          const res = await fetch(leadForm.action, {
            method: "POST",
            body: data,
            headers: { Accept: "application/json" },
          });

          if (res.ok) {
            // Open the teardown in a new tab AND show success state on this page
            window.open(
              "/resources/5-site-teardown/index.html",
              "_blank",
              "noopener,noreferrer",
            );
            leadForm.classList.add("hidden");
            leadSuccess?.classList.remove("hidden");
          } else {
            leadBtn.disabled = false;
            leadBtn.textContent = leadBtnText ?? "Get the teardown";
            leadBtn.classList.remove("opacity-60");
            alert("Something went wrong. Try again?");
          }
        } catch {
          leadBtn.disabled = false;
          leadBtn.textContent = leadBtnText ?? "Get the teardown";
          leadBtn.classList.remove("opacity-60");
          alert("Network error. Try again?");
        }
      });
    </script>
