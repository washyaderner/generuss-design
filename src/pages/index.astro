        <script>
          // Tier ladder: click a card, the detail panel below swaps to match.
          const tierCards = Array.from(
            document.querySelectorAll<HTMLElement>("[data-tier]"),
          );
          const tierPanels: Record<string, HTMLElement | null> = {
            launch: document.getElementById("tier-panel-launch"),
            flagship: document.getElementById("tier-panel-flagship"),
            growth: document.getElementById("tier-panel-growth"),
          };

          function selectTier(key: string) {
            tierCards.forEach((card) => {
              const active = card.getAttribute("data-tier") === key;
              card.classList.toggle("border-accent/40", active);
              card.classList.toggle("border-transparent", !active);
              card.setAttribute("aria-pressed", String(active));
            });
            Object.entries(tierPanels).forEach(([k, el]) => {
              el?.classList.toggle("hidden", k !== key);
            });
          }

          tierCards.forEach((card) => {
            card.addEventListener("click", () => {
              const key = card.getAttribute("data-tier");
              if (key) selectTier(key);
            });
            card.addEventListener("keydown", (e) => {
              if (e.key === "Enter" || e.key === " ") {
                e.preventDefault();
                const key = card.getAttribute("data-tier");
                if (key) selectTier(key);
              }
            });
          });
        </script>

