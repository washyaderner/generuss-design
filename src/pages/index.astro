  <script>
    let loaded = false;
    const initAnimations = () => {
      if (loaded) return;
      loaded = true;
      // Lenis smooth scroll must init before scroll-manager
      import("../scripts/smooth-scroll.js").then(() => {
        import("../scripts/scroll-manager.js");
      });
    };

    // Fire on first scroll if idle callback hasn't triggered yet
    window.addEventListener("scroll", initAnimations, { once: true });

    if ("requestIdleCallback" in window) {
      requestIdleCallback(initAnimations, { timeout: 1000 });
    } else {
      setTimeout(initAnimations, 150);
    }
  </script>

  <!-- Fallback: reveal gsap-hidden elements via IntersectionObserver -->
  <!-- Independent of GSAP/Lenis module loading -->
  <script>
    const _io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.remove("gsap-hidden");
            e.target.style.opacity = "1";
            e.target.style.visibility = "visible";
            _io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.01, rootMargin: "100px 0px" },
    );
    // Reveal hidden elements quickly. ScrollTrigger gets a small head start (50ms)
    // to claim what it can, then IntersectionObserver picks up everything else.
    setTimeout(() => {
      document
        .querySelectorAll(".gsap-hidden")
        .forEach((el) => _io.observe(el));
    }, 50);
  </script>
