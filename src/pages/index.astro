          class="inline-block rounded-full bg-accent px-10 py-4 text-lg font-semibold text-[#0C0C0C] transition-shadow duration-200 hover:shadow-[0_0_30px_var(--color-accent-mid)]"
        >
          Let's build yours &rarr;
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const initAnimations = () => import("../scripts/scroll-manager.js");

    if ("requestIdleCallback" in window) {
      requestIdleCallback(initAnimations, { timeout: 2000 });
    } else {
      setTimeout(initAnimations, 200);
    }
  </script>
