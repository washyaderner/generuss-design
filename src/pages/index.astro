    <script>
      // Portfolio modal logic
      const modal = document.getElementById("portfolio-modal");
      const iframeMode = document.getElementById("modal-iframe-mode");
      const imageMode = document.getElementById("modal-image-mode");
      const modalIframe = document.getElementById(
        "modal-iframe",
      ) as HTMLIFrameElement;
      const modalSpinner = document.getElementById("modal-spinner");
      const modalUrlDisplay = document.getElementById("modal-url-display");
      const modalTitle = document.getElementById("modal-title");
      const modalTitleMobile = document.getElementById("modal-title-mobile");
      const modalDesc = document.getElementById("modal-description");
      const modalStack = document.getElementById("modal-stack");
      const modalLink = document.getElementById(
        "modal-link",
      ) as HTMLAnchorElement;
      const modalLinkMobile = document.getElementById(
        "modal-link-mobile",
      ) as HTMLAnchorElement;
      const modalImg = document.getElementById("modal-img") as HTMLImageElement;

      let spinnerTimeout: ReturnType<typeof setTimeout> | null = null;

      function isDesktop() {
        return window.innerWidth >= 768;
      }

      function openModal(card: HTMLElement) {
        const title = card.dataset.title || "";
        const desc = card.dataset.description || "";
        const url = card.dataset.url || "#";
        const stack = (card.dataset.stack || "")
          .split(",")
          .map((s) => s.trim())
          .filter(Boolean);

        if (isDesktop()) {
          // Iframe mode
          iframeMode?.classList.remove("hidden");
          iframeMode?.classList.add("flex");
          imageMode?.classList.add("hidden");

          if (modalTitle) modalTitle.textContent = title;
          if (modalUrlDisplay) modalUrlDisplay.textContent = url;
          if (modalLink) modalLink.href = url;

          // Show spinner, load iframe
          modalSpinner?.classList.remove("hidden");
          if (modalIframe) {
            modalIframe.onload = () => {
              modalSpinner?.classList.add("hidden");
              if (spinnerTimeout) clearTimeout(spinnerTimeout);
            };
            modalIframe.src = url;
          }

          // Fallback: hide spinner after 8s even if onload doesn't fire
          spinnerTimeout = setTimeout(() => {
            modalSpinner?.classList.add("hidden");
          }, 8000);
        } else {
          // Image mode (mobile)
          imageMode?.classList.remove("hidden");
          iframeMode?.classList.add("hidden");
          iframeMode?.classList.remove("flex");

          const imgSrc = card.dataset.imageMobile || card.dataset.imageDesktop;
          if (modalTitleMobile) modalTitleMobile.textContent = title;
          if (modalDesc) modalDesc.textContent = desc;
          if (modalLinkMobile) modalLinkMobile.href = url;
          if (modalImg && imgSrc) {
            modalImg.src = imgSrc;
            modalImg.alt = `${title} screenshot`;
          }
          if (modalStack) {
            modalStack.innerHTML = stack
              .map(
                (t) =>
                  `<span class="border border-accent/30 rounded-full px-3 py-1 text-xs font-mono text-accent">${t}</span>`,
              )
              .join("");
          }
        }

        modal?.classList.remove("hidden");
        modal?.classList.add("flex");
        document.body.style.overflow = "hidden";

        // Focus the appropriate close button
        const focusTarget = isDesktop()
          ? document.getElementById("modal-close")
          : document.getElementById("modal-close-mobile");
        (focusTarget as HTMLElement)?.focus();
      }

      function closeModal() {
        modal?.classList.add("hidden");
        modal?.classList.remove("flex");
        iframeMode?.classList.add("hidden");
        iframeMode?.classList.remove("flex");
        imageMode?.classList.add("hidden");
        document.body.style.overflow = "";

        // Clear iframe to free resources
        if (modalIframe) {
          modalIframe.src = "";
          modalIframe.onload = null;
        }
        if (spinnerTimeout) {
          clearTimeout(spinnerTimeout);
          spinnerTimeout = null;
        }
      }

      document.querySelectorAll(".portfolio-card").forEach((card) => {
        card.addEventListener("click", () => openModal(card as HTMLElement));
      });

      // Close handlers - all buttons
      [
        "modal-close",
        "modal-close-btn",
        "modal-close-mobile",
        "modal-close-btn-mobile",
      ].forEach((id) => {
        document.getElementById(id)?.addEventListener("click", closeModal);
      });

      // Backdrop click
      modal?.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
      });

      // Keyboard: Escape + focus trap
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modal?.classList.contains("hidden"))
          closeModal();
        if (e.key === "Tab" && !modal?.classList.contains("hidden")) {
          const activeContainer = isDesktop() ? iframeMode : imageMode;
          const focusable = activeContainer?.querySelectorAll<HTMLElement>(
            'a, button, iframe, [tabindex]:not([tabindex="-1"])',
          );
          if (!focusable?.length) return;
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      });
    </script>

