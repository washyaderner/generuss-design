    <script>
      // --- Synced card slideshows (desktop + mobile per card) ---
      document.querySelectorAll(".portfolio-card").forEach((card) => {
        const slideshows = card.querySelectorAll(".portfolio-slideshow");
        if (slideshows.length < 2) return;

        // Build per-slideshow state
        const shows = Array.from(slideshows).map((container) => ({
          slides: container.querySelectorAll<HTMLImageElement>(".slide"),
          dots: container.querySelectorAll<HTMLButtonElement>(".dot"),
        }));

        const maxSlides = Math.min(...shows.map((s) => s.slides.length));
        if (maxSlides < 2) return;

        let current = 0;
        let interval: ReturnType<typeof setInterval> | null = null;

        function goTo(index: number) {
          const next = ((index % maxSlides) + maxSlides) % maxSlides;
          shows.forEach(({ slides, dots }) => {
            // hide current
            if (current < slides.length) {
              slides[current].classList.remove("active");
              slides[current].style.opacity = "0";
            }
            if (current < dots.length) {
              dots[current].classList.remove("bg-white/80");
              dots[current].classList.add("bg-white/30");
            }
            // show next
            if (next < slides.length) {
              slides[next].classList.add("active");
              slides[next].style.opacity = "1";
            }
            if (next < dots.length) {
              dots[next].classList.remove("bg-white/30");
              dots[next].classList.add("bg-white/80");
            }
          });
          current = next;
        }

        function startAuto() {
          stopAuto();
          interval = setInterval(() => goTo(current + 1), 4000);
        }

        function stopAuto() {
          if (interval) {
            clearInterval(interval);
            interval = null;
          }
        }

        // Dot clicks on either slideshow sync both
        shows.forEach(({ dots }) => {
          dots.forEach((dot, i) => {
            dot.addEventListener("click", (e) => {
              e.stopPropagation();
              goTo(i);
              startAuto();
            });
          });
        });

        // Pause on hover (either slideshow)
        slideshows.forEach((container) => {
          container.addEventListener("mouseenter", stopAuto);
          container.addEventListener("mouseleave", () => {
            if (isVisible) startAuto();
          });
        });

        // Only run when card is visible
        let isVisible = false;
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              isVisible = entry.isIntersecting;
              if (isVisible) {
                startAuto();
              } else {
                stopAuto();
              }
            });
          },
          { threshold: 0.1 },
        );
        observer.observe(card);
      });

      // Make [data-url] showcase cards clickable, parity with the <a> cards
      // above so the section's "Click any to see the live site" promise holds.
      document.querySelectorAll(".portfolio-card[data-url]").forEach((card) => {
        const url = card.getAttribute("data-url");
        if (!url) return;
        (card as HTMLElement).style.cursor = "pointer";
        card.addEventListener("click", (e) => {
          if ((e.target as HTMLElement).closest(".dot")) return;
          window.open(url, "_blank", "noopener,noreferrer");
        });
      });
    </script>

