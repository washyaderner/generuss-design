            style="display:none"
            tabindex="-1"
            autocomplete="off"
          />

          <div>
            <label for="name" class="block text-sm text-text-muted mb-1"
              >Name</label
            >
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full rounded-xl bg-bg px-4 py-3 text-text placeholder:text-text-muted/50 neu-inset focus:outline-none focus:ring-1 focus:ring-accent/50"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="block text-sm text-text-muted mb-1"
              >Email</label
            >
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full rounded-xl bg-bg px-4 py-3 text-text placeholder:text-text-muted/50 neu-inset focus:outline-none focus:ring-1 focus:ring-accent/50"
              placeholder="you@company.com"
            />
          </div>

          <div>
            <label for="message" class="block text-sm text-text-muted mb-1"
              >Message</label
            >
            <textarea
              id="message"
              name="message"
              required
              rows="3"
              class="w-full rounded-xl bg-bg px-4 py-3 text-text placeholder:text-text-muted/50 neu-inset focus:outline-none focus:ring-1 focus:ring-accent/50 resize-none"
              placeholder="Tell me about your project..."></textarea>
          </div>

          <button
            type="submit"
            class="w-full sm:w-auto rounded-full border border-accent px-8 py-3 text-base font-semibold text-accent transition-all duration-200 hover:bg-accent hover:text-[#0C0C0C] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            Send Message &rarr;
          </button>
        </form>

        <!-- Success state -->
        <div id="form-success" class="hidden text-center py-8">
          <p class="text-lg text-text">
            Message sent. I'll be <span class="text-accent">in touch.</span>
          </p>
        </div>
      </div>
    </section>

    <script>
      // Contact form handling
      const form = document.getElementById("contact-form") as HTMLFormElement;
      const successMsg = document.getElementById("form-success");
      const submitBtn = form?.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement;
      const submitText = submitBtn?.textContent;

      form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(form);

        submitBtn.disabled = true;
        submitBtn.textContent = "Sending...";
        submitBtn.classList.add("opacity-50", "cursor-not-allowed");

        try {
          const res = await fetch(form.action, {
            method: "POST",
            body: data,
            headers: { Accept: "application/json" },
          });

          if (res.ok) {
            form.classList.add("hidden");
            successMsg?.classList.remove("hidden");
          } else {
            submitBtn.disabled = false;
            submitBtn.textContent = submitText ?? "Send Message →";
            submitBtn.classList.remove("opacity-50", "cursor-not-allowed");
            alert("Something went wrong. Please try again.");
          }
        } catch {
          submitBtn.disabled = false;
          submitBtn.textContent = submitText ?? "Send Message →";
          submitBtn.classList.remove("opacity-50", "cursor-not-allowed");
          alert("Network error. Please try again.");
        }
      });
    </script>
  </main>

  <Footer />

  <script>
    import "../scripts/scroll-manager.js";
  </script>

  <!-- Cal.com embed: lazy-loaded via IntersectionObserver for Lighthouse perf -->
  <script is:inline>
    (function () {
      var contactSection = document.getElementById("contact");
      var calSkeleton = document.getElementById("cal-skeleton");
      var calLoaded = false;

      var observer = new IntersectionObserver(
        function (entries) {
          if (entries[0].isIntersecting && !calLoaded) {
            calLoaded = true;
            observer.disconnect();
            loadCalEmbed();
          }
        },
        { rootMargin: "600px" },
      );

      if (contactSection) observer.observe(contactSection);

      function loadCalEmbed() {
        // Cal.com official embed snippet
        (function (C, A, L) {
          var p = function (a, ar) {
            a.q.push(ar);
          };
          var d = C.document;
          C.Cal =
            C.Cal ||
            function () {
              var cal = C.Cal;
              var ar = arguments;
              if (!cal.loaded) {
                cal.ns = {};
                cal.q = cal.q || [];
                d.head.appendChild(d.createElement("script")).src = A;
                cal.loaded = true;
              }
              if (ar[0] === L) {
                var api = function () {
                  p(api, arguments);
                };
                var namespace = ar[1];
                api.q = api.q || [];
                if (typeof namespace === "string") {
                  cal.ns[namespace] = cal.ns[namespace] || api;
                  p(cal.ns[namespace], ar);
                  p(cal, ["initNamespace", namespace]);
                } else p(cal, ar);
                return;
              }
              p(cal, ar);
            };
        })(window, "https://app.cal.com/embed/embed.js", "init");

        window.Cal("init", "discovery-call", { origin: "https://app.cal.com" });

        window.Cal.ns["discovery-call"]("inline", {
          elementOrSelector: "#cal-embed",
          calLink: "generuss/discovery-call",
          layout: "month_view",
        });

        window.Cal.ns["discovery-call"]("ui", {
          theme: "dark",
          hideEventTypeDetails: false,
          layout: "month_view",
        });

        // Hide skeleton once Cal iframe renders
        var calEl = document.getElementById("cal-embed");
        if (calEl && calSkeleton) {
          var mo = new MutationObserver(function () {
            if (calEl.querySelector("iframe")) {
              calSkeleton.style.display = "none";
              mo.disconnect();
            }
          });
          mo.observe(calEl, { childList: true, subtree: true });
        }
      }
    })();
  </script>
</BaseLayout>
