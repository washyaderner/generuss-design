---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/plates/Hero.astro";
import ProofStrip from "../components/plates/ProofStrip.astro";
import Leaks from "../components/plates/Leaks.astro";
import BuiltWork from "../components/plates/BuiltWork.astro";
import BillOfMaterials from "../components/plates/BillOfMaterials.astro";
import Method from "../components/plates/Method.astro";
import FieldReports from "../components/plates/FieldReports.astro";
import Draftsman from "../components/plates/Draftsman.astro";
import GuaranteePlate from "../components/plates/GuaranteePlate.astro";
import FaqPlate, { faqs } from "../components/plates/FaqPlate.astro";
import BookingPlate from "../components/plates/BookingPlate.astro";

const offerSchema = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "@id": "https://generussdesign.com/#offers",
  name: "generuss design services",
  itemListElement: [
    {
      "@type": "Offer",
      name: "The Launch Page",
      description:
        "One-page hand-built website, live in 7 days, booking wired, hosting included. Credits toward the Flagship build for 6 months.",
      price: "500",
      priceCurrency: "USD",
    },
    {
      "@type": "Offer",
      name: "The Conversion-Engineered Site",
      description:
        "Full custom website build: strategy, conversion-first copy, design, and automation. Live in 21 days or you don't pay the balance.",
      priceSpecification: {
        "@type": "PriceSpecification",
        minPrice: 4500,
        priceCurrency: "USD",
      },
    },
    {
      "@type": "Offer",
      name: "The Growth Engine",
      description:
        "Monthly search + AI visibility optimization across nine surfaces: SEO, AEO, GEO, local, voice, performance, CRO, email, social.",
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        minPrice: 750,
        priceCurrency: "USD",
        unitText: "month",
      },
    },
  ],
};

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://generussdesign.com/",
      name: "generuss design | Custom Websites That Convert",
      isPartOf: { "@id": "https://generussdesign.com/#website" },
      speakable: {
        "@type": "SpeakableSpecification",
        cssSelector: ["#hero h1", "#hero p"],
      },
    },
    {
      "@type": "FAQPage",
      "@id": "https://generussdesign.com/#faq",
      mainEntity: faqs.map((f) => ({
        "@type": "Question",
        name: f.q,
        acceptedAnswer: { "@type": "Answer", text: f.a },
      })),
    },
  ],
};
---

<BaseLayout
  title="generuss design | Custom Websites That Convert"
  description="Hand-built websites from $500 to full conversion-engineered builds, plus SEO, AEO + GEO optimization. No templates, no bloat, one human accountable."
>
  <Nav />

  <script type="application/ld+json" set:html={JSON.stringify(offerSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

  <main id="main-content" class="relative">
    <Hero />
    <ProofStrip />
    <Leaks />
    <BuiltWork />
    <BillOfMaterials />
    <Method />
    <FieldReports />
    <Draftsman />
    <GuaranteePlate />
    <FaqPlate />
    <BookingPlate />
  </main>

  <Footer />
</BaseLayout>
