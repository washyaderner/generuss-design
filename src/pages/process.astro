---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { breadcrumbs } from "../lib/schema";

const base = String(Astro.site);

// Speed receipts: PageSpeed Insights, homepage, 2026-07-14 audit.
// Cited exactly as measured, no rounding up.
const speedStats = [
  { value: "86", label: "PageSpeed, mobile" },
  { value: "100", label: "PageSpeed, desktop" },
  { value: "0", label: "Layout shift (CLS)" },
];

const steps = [
  {
    n: "01",
    name: "Discovery",
    body: "We start with what the site is actually for: who buys, what they need to see, and the one action that matters most. No wireframe theater, just the decisions that shape everything after.",
  },
  {
    n: "02",
    name: "Design direction",
    body: "You see a real design direction before you commit further, not a stock template preview. If it is not right for you, your deposit comes back. When it lands, I build straight from it.",
  },
  {
    n: "03",
    name: "Hand-coded build",
    body: "I build the site by hand in Astro. Every section is written to load fast and read cleanly to both people and search engines. No page builder, no drag-and-drop debt, no plugins bolted on to paper over the gaps.",
  },
  {
    n: "04",
    name: "Launch in 21 days",
    body: "Your site goes live within 21 days of kickoff, on free Cloudflare hosting. Miss that mark and you do not pay the balance until it is live. Then the domain, the code, and the content are yours to keep.",
  },
];

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${base}process`,
      url: `${base}process`,
      name: "Astro Web Designer: My Build Process",
      description:
        "How I build websites as a hand-coded Astro web designer: the process, why hand-coded Astro beats page builders, and the real speed numbers to prove it.",
      isPartOf: { "@id": `${base}#website` },
      about: { "@id": `${base}#org` },
    },
    breadcrumbs(base, [
      { name: "Home", path: "/" },
      { name: "Build Process", path: "/process" },
    ]),
    {
      "@type": "Service",
      "@id": `${base}process#service`,
      name: "Hand-Coded Astro Website Design",
      serviceType: "Custom website design and development",
      description:
        "Custom hand-coded websites built in Astro and hosted on Cloudflare: fast, owned by the client, live in 21 days.",
      provider: { "@id": `${base}#org` },
      url: `${base}process`,
    },
  ],
};
---

<BaseLayout
  title="Astro Web Designer: My Build Process"
  description="How I build sites as a hand-coded Astro web designer: the process, why hand-coded Astro beats page builders, and the real speed numbers to prove it."
>
  <Nav bookingHref="/#booking" offerHref="/#offer" />

  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

  <main id="main-content">
    <!-- ===== HERO ===== -->
    <section
      id="hero"
      class="relative flex min-h-screen min-h-[100dvh] items-center overflow-hidden px-6 sm:px-10 lg:px-16 pt-24 pb-12 lg:pt-28"
    >
      <div class="relative z-10 w-full max-w-4xl mx-auto">
        <div class="max-w-3xl mx-auto text-center">
          <span
            class="hero-enter hero-enter-1 inline-flex items-center gap-2 mb-5 text-[0.7rem] sm:text-xs font-mono text-accent uppercase tracking-[0.2em]"
          >
            <span
              class="inline-block h-1.5 w-1.5 rounded-full bg-accent shadow-[0_0_10px_var(--color-accent-glow)]"
            ></span>
            Hand-coded Astro web designer
          </span>
          <h1
            class="hero-enter hero-enter-2 text-balance text-[2.4rem] sm:text-[3.1rem] md:text-[3.6rem] lg:text-[3.9rem] xl:text-[4.3rem] font-black tracking-[-0.03em] leading-[1.03] text-text"
          >
            How your website
            <span class="text-accent glow-text">actually gets built.</span>
          </h1>
          <p
            class="hero-enter hero-enter-3 mt-6 text-pretty text-lg sm:text-xl md:text-[1.3rem] text-text-muted leading-relaxed max-w-2xl mx-auto"
          >
            I am an Astro web designer, which means I hand-code sites instead of
            assembling them on a page builder. No templates, no plugin sprawl,
            no monthly platform tax. Here is exactly how a build runs, and the
            speed numbers that come out the other side.
          </p>

          <div
            class="hero-enter hero-enter-4 mt-8 flex flex-col sm:flex-row items-center justify-center gap-4"
          >
            <a
              href="#steps"
              class="rounded-full bg-accent px-8 py-3.5 text-base font-semibold text-[#0C0C0C] min-h-[44px] inline-flex items-center justify-center transition-shadow duration-200 hover:shadow-[0_0_30px_var(--color-accent-mid)]"
            >
              See the process &rarr;
            </a>
            <a
              href="/#booking"
              class="rounded-full border border-border px-7 py-3.5 text-base font-semibold text-text min-h-[44px] inline-flex items-center justify-center transition-colors duration-200 hover:border-accent/50 hover:text-accent"
            >
              Book a Call
            </a>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div
        class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-60"
      >
        <span
          class="text-[0.6rem] text-text-muted font-mono tracking-[0.2em] uppercase"
          >Scroll</span
        >
        <div class="h-6 w-px bg-text-muted/40"></div>
      </div>
    </section>

    <!-- ===== WHY HAND-CODED ASTRO ===== -->
    <section
      id="why"
      class="relative z-10 bg-bg-secondary section-fade-in section-fade-from-dark px-6 sm:px-10 lg:px-16 py-(--spacing-section)"
    >
      <div class="max-w-4xl mx-auto">
        <p
          class="inline-flex items-center gap-2 text-[0.65rem] sm:text-xs font-mono text-accent uppercase tracking-[0.2em] mb-4"
        >
          <span class="h-px w-8 bg-accent/60"></span>
          Why hand-coded Astro
        </p>
        <h2
          class="text-balance text-3xl sm:text-4xl md:text-5xl font-black tracking-tight leading-[1.05] mb-6"
        >
          The tool decides <span class="text-accent">how fast you load.</span>
        </h2>
        <div
          class="space-y-5 text-pretty text-base sm:text-lg text-text-muted leading-relaxed max-w-3xl"
        >
          <p>
            Most websites are heavy because of how they are made, not what they
            say. A page builder ships a pile of scripts to every visitor so its
            editor can work, whether your page uses them or not. That weight is
            why template sites feel sluggish, and it is baked in before you
            write a single word.
          </p>
          <p>
            Astro takes the opposite approach. It renders your pages to plain,
            fast HTML and sends almost no JavaScript unless a specific piece
            genuinely needs it. Hand-coding on top of that means the site
            carries only what it uses. The result is a page that loads quickly,
            reads cleanly to Google and to AI assistants, and does not sag under
            a traffic spike.
          </p>
          <p>
            It also means you own something real: a clean codebase and your own
            domain, hosted free, with no platform to escape later. You can weigh
            that against the other ways to buy a site on the
            <a href="/compare" class="text-accent hover:underline"
              >cost comparison page</a
            >.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== THE SPEED RECEIPTS ===== -->
    <section
      id="receipts"
      class="relative z-10 px-6 sm:px-10 lg:px-16 py-(--spacing-section)"
    >
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10 sm:mb-12">
          <p
            class="inline-flex items-center gap-2 text-[0.65rem] sm:text-xs font-mono text-accent uppercase tracking-[0.2em] mb-4"
          >
            <span class="h-px w-8 bg-accent/60"></span>
            The receipts
          </p>
          <h2
            class="text-balance text-3xl sm:text-4xl md:text-5xl font-black tracking-tight leading-[1.05]"
          >
            Not a claim. <span class="text-accent">A measurement.</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
          {
            speedStats.map((s) => (
              <div class="neu-raised rounded-2xl bg-bg p-6 sm:p-8 flex flex-col items-center text-center">
                <span class="text-5xl sm:text-6xl font-black text-accent glow-text tracking-tight">
                  {s.value}
                </span>
                <span class="mt-3 text-sm text-text-muted font-mono uppercase tracking-[0.12em]">
                  {s.label}
                </span>
              </div>
            ))
          }
        </div>

        <p
          class="mt-6 text-center text-sm text-text-muted/80 leading-relaxed max-w-2xl mx-auto"
        >
          This site's own homepage, measured on Google PageSpeed Insights in the
          2026-07-14 audit: 86 on mobile, 100 on desktop, with zero cumulative
          layout shift. Real numbers from the tool anyone can run, not a rounded
          badge. The mobile score has room to climb, and it is on the list.
        </p>
      </div>
    </section>

    <!-- ===== THE PROCESS STEPS ===== -->
    <section
      id="steps"
      class="relative z-10 bg-bg-secondary section-fade-in section-fade-from-secondary px-6 sm:px-10 lg:px-16 py-(--spacing-section)"
    >
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10 sm:mb-14">
          <p
            class="inline-flex items-center gap-2 text-[0.65rem] sm:text-xs font-mono text-accent uppercase tracking-[0.2em] mb-4"
          >
            <span class="h-px w-8 bg-accent/60"></span>
            The build, step by step
          </p>
          <h2
            class="text-balance text-3xl sm:text-4xl md:text-5xl font-black tracking-tight leading-[1.05]"
          >
            Four steps, <span class="text-accent">21 days.</span>
          </h2>
        </div>

        <div class="space-y-6">
          {
            steps.map((s) => (
              <div class="neu-raised rounded-2xl bg-bg p-6 sm:p-8 flex gap-5">
                <span class="font-mono text-accent font-bold text-lg shrink-0">
                  {s.n}
                </span>
                <div>
                  <h3 class="text-lg font-bold text-text mb-2">{s.name}</h3>
                  <p class="text-pretty text-sm sm:text-base text-text-muted leading-relaxed">
                    {s.body}
                  </p>
                </div>
              </div>
            ))
          }
        </div>

        <p
          class="mt-8 text-center text-sm sm:text-base text-text-muted leading-relaxed"
        >
          Want to see it applied to a real project? Read the
          <a href="/ogc" class="text-accent hover:underline"
            >Oregon Ghost Conference build</a
          >, or see how the same care extends to
          <a href="/seo" class="text-accent hover:underline"
            >search and AI visibility</a
          >.
        </p>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section
      id="cta"
      class="px-8 sm:px-12 lg:px-20 py-(--spacing-section) relative"
    >
      <div
        class="absolute inset-0 pointer-events-none flex items-center justify-center"
      >
        <div
          class="w-[600px] h-[600px] rounded-full bg-accent/[0.04] blur-[120px]"
        >
        </div>
      </div>

      <div class="relative z-10 max-w-2xl mx-auto text-center">
        <p
          class="inline-flex items-center gap-2 text-[0.65rem] sm:text-xs font-mono text-accent uppercase tracking-[0.2em] mb-4"
        >
          <span class="h-px w-8 bg-accent/60"></span>
          The next step
        </p>
        <h2
          class="text-balance text-3xl sm:text-4xl md:text-5xl font-black tracking-tight leading-[1.05] mb-5"
        >
          Ready to build <span class="text-accent glow-text"
            >something fast?</span
          >
        </h2>
        <p
          class="text-pretty text-base sm:text-lg text-text-muted leading-relaxed max-w-xl mx-auto mb-8"
        >
          Book a quick call and I will walk you through how I would build your
          site, what it costs, and the timeline. Whether we work together or
          not, you leave with a plan.
        </p>
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4"
        >
          <a
            href="/#booking"
            class="rounded-full bg-accent px-8 py-3.5 text-base font-semibold text-[#0C0C0C] min-h-[44px] inline-flex items-center justify-center transition-shadow duration-200 hover:shadow-[0_0_30px_var(--color-accent-mid)]"
          >
            Book a Call &rarr;
          </a>
          <a
            href="/taste-audit"
            class="rounded-full border border-border px-7 py-3.5 text-base font-semibold text-text min-h-[44px] inline-flex items-center justify-center transition-colors duration-200 hover:border-accent/50 hover:text-accent"
          >
            Start with a Taste Audit
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <style is:global>
    html {
      scroll-behavior: smooth;
    }
  </style>
</BaseLayout>
