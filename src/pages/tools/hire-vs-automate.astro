---
import ToolShell from "../../components/ToolShell.astro";

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID || "xgolkboq";
---

<ToolShell
  title="Hire vs. Automate Calculator: The Honest Math | generuss design"
  description="Compare hiring for a task against automating it over three years: true loaded costs, the crossover point, and which one your volume actually justifies. Free and instant."
  kicker="Free calculator · instant"
  heading="Hire someone,"
  headingAccent="or wire it once?"
  sub="The task keeps eating your week. One option costs a salary every year; the other costs a build once plus upkeep. Put in your real numbers and see where the lines cross."
  slug="hire-vs-automate"
  toolName="Hire vs. Automate Calculator"
  related={[
    { name: "Workflow Automation Score", href: "/tools/automation-score" },
    { name: "Missed-Lead Calculator", href: "/tools/missed-lead-calculator" },
  ]}
  ctaHeading="Automation winning your math?"
  ctaSub="I build automations for service businesses: speed-to-lead, follow-up, reviews, CRM wiring. Fixed scope, documented, maintained. Free call, real plan either way."
>
  <section class="px-6 sm:px-10 lg:px-16 pb-4">
    <div class="max-w-2xl mx-auto">
      <div class="neu-raised rounded-3xl bg-bg p-6 sm:p-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="hva-hours" class="block text-sm text-text-muted mb-1"
              >Hours per week the task takes</label
            >
            <input
              type="number"
              id="hva-hours"
              min="0"
              step="0.5"
              value="10"
              class="w-full rounded-xl bg-bg px-4 py-3 text-text neu-inset focus:outline-none focus:ring-1 focus:ring-accent/50"
            />
          </div>
          <div>
            <label for="hva-rate" class="block text-sm text-text-muted mb-1"
              >What an hour of that work costs ($)</label
            >
            <input
              type="number"
              id="hva-rate"
              min="0"
              value="30"
              class="w-full rounded-xl bg-bg px-4 py-3 text-text neu-inset focus:outline-none focus:ring-1 focus:ring-accent/50"
            />
            <p class="mt-1.5 text-xs text-text-muted/70">
              A hire's loaded hourly rate, or your own time's value if it's you
              doing it.
            </p>
          </div>
          <div>
            <label for="hva-build" class="block text-sm text-text-muted mb-1"
              >One-time automation build cost ($)</label
            >
            <input
              type="number"
              id="hva-build"
              min="0"
              value="2500"
              class="w-full rounded-xl bg-bg px-4 py-3 text-text neu-inset focus:outline-none focus:ring-1 focus:ring-accent/50"
            />
          </div>
          <div>
            <label for="hva-monthly" class="block text-sm text-text-muted mb-1"
              >Automation upkeep per month ($)</label
            >
            <input
              type="number"
              id="hva-monthly"
              min="0"
              value="100"
              class="w-full rounded-xl bg-bg px-4 py-3 text-text neu-inset focus:outline-none focus:ring-1 focus:ring-accent/50"
            />
          </div>
          <div class="sm:col-span-2">
            <label for="hva-pct" class="block text-sm text-text-muted mb-1"
              >Share of the task automation can realistically handle (<span
                id="hva-pct-val"
                class="text-accent font-mono">80</span
              >%)</label
            >
            <input
              type="range"
              id="hva-pct"
              min="20"
              max="100"
              step="5"
              value="80"
              class="w-full accent-[#00FFEF]"
            />
            <p class="mt-1.5 text-xs text-text-muted/70">
              Rule-based, repetitive, digital tasks sit high on this slider.
              Judgment-heavy work sits low, and a hire may honestly win.
            </p>
          </div>
        </div>

        <div class="mt-7 neu-inset rounded-2xl p-6">
          <p
            class="text-center text-[0.65rem] font-mono text-text-muted/70 uppercase tracking-[0.2em] mb-4"
          >
            Three-year comparison, your numbers
          </p>
          <div class="grid grid-cols-2 gap-4 text-center">
            <div>
              <p class="text-xs font-mono text-text-muted mb-1">
                Keep paying hourly
              </p>
              <p
                id="hva-hire"
                class="text-2xl sm:text-3xl font-black text-text"
              >
                $0
              </p>
            </div>
            <div>
              <p class="text-xs font-mono text-text-muted mb-1">Automate it</p>
              <p
                id="hva-auto"
                class="text-2xl sm:text-3xl font-black text-accent glow-text"
              >
                $0
              </p>
            </div>
          </div>
          <p
            id="hva-verdict"
            class="text-pretty mt-4 text-center text-sm text-text-muted font-mono"
          >
          </p>
        </div>
      </div>

      <!-- Email gate -->
      <div class="mt-8 neu-raised rounded-3xl bg-bg p-6 sm:p-8">
        <p
          class="text-[0.65rem] font-mono text-accent uppercase tracking-[0.2em] mb-1.5"
        >
          Want a real quote instead of a slider?
        </p>
        <h3 class="text-balance text-lg font-bold text-text mb-1.5">
          Describe the task, get the actual build price
        </h3>
        <p class="text-pretty text-sm text-text-muted leading-relaxed mb-4">
          One paragraph about the task and your tools. I reply with what's
          automatable, what it costs, and what to skip. One email, no drip
          campaign.
        </p>
        <form
          id="hva-form"
          action={`https://formspree.io/f/${formspreeId}`}
          method="POST"
          class="flex flex-col gap-3"
        >
          <input
            type="text"
            name="_gotcha"
            style="display:none"
            tabindex="-1"
            autocomplete="off"
          />
          <input
            type="hidden"
            name="_subject"
            value="Hire vs Automate quote request"
          />
          <input type="hidden" name="source" value="hire-vs-automate" />
          <input type="hidden" name="calc_inputs" id="hva-payload" value="" />
          <textarea
            name="task_description"
            required
            rows="3"
            placeholder="The task, roughly how it flows, and the tools involved..."
            class="w-full rounded-2xl bg-bg px-4 py-3 text-sm text-text placeholder:text-text-muted/50 neu-inset focus:outline-none focus:ring-1 focus:ring-accent/50 resize-none"
          ></textarea>
          <div class="flex flex-col sm:flex-row gap-3">
            <label class="sr-only" for="hva-email">Email address</label>
            <input
              type="email"
              id="hva-email"
              name="email"
              required
              placeholder="you@yourbusiness.com"
              class="w-full flex-1 rounded-full bg-bg px-4 py-3 text-sm text-text placeholder:text-text-muted/50 neu-inset focus:outline-none focus:ring-1 focus:ring-accent/50 min-h-[44px]"
            />
            <button
              type="submit"
              class="rounded-full bg-accent px-5 py-3 text-sm font-semibold text-[#0C0C0C] min-h-[44px] inline-flex items-center justify-center transition-shadow duration-200 hover:shadow-[0_0_20px_var(--color-accent-mid)]"
            >
              Get the real quote &rarr;
            </button>
          </div>
        </form>
        <p
          id="hva-form-success"
          class="hidden text-sm text-accent mt-3 font-mono"
        >
          On its way. Check your inbox today.
        </p>
      </div>
    </div>
  </section>

  <script>
    const h = (id: string) => document.getElementById(id) as HTMLInputElement;
    const cash = (n: number) => "$" + Math.round(n).toLocaleString("en-US");

    function calcHva() {
      const hours = Number(h("hva-hours").value) || 0;
      const rate = Number(h("hva-rate").value) || 0;
      const build = Number(h("hva-build").value) || 0;
      const upkeep = Number(h("hva-monthly").value) || 0;
      const pct = (Number(h("hva-pct").value) || 0) / 100;
      document.getElementById("hva-pct-val")!.textContent = h("hva-pct").value;

      const YEARS = 3;
      const hireCost = hours * 52 * YEARS * rate;
      // Automation covers pct of the task; the remainder stays human + paid.
      const autoCost =
        build + upkeep * 12 * YEARS + hours * 52 * YEARS * rate * (1 - pct);
      const savings = hireCost - autoCost;

      document.getElementById("hva-hire")!.textContent = cash(hireCost);
      document.getElementById("hva-auto")!.textContent = cash(autoCost);

      const verdict = document.getElementById("hva-verdict")!;
      if (savings > 0) {
        const monthlySpend = hours * 4.33 * rate * pct - upkeep;
        const breakevenMonths =
          monthlySpend > 0 ? Math.ceil(build / monthlySpend) : Infinity;
        verdict.textContent =
          breakevenMonths === Infinity
            ? `Automation saves ${cash(savings)} over 3 years.`
            : `Automation saves ${cash(savings)} over 3 years and pays for itself in about ${breakevenMonths} month${breakevenMonths === 1 ? "" : "s"}.`;
      } else if (savings < 0) {
        verdict.textContent = `At this volume, hiring (or keeping it manual) wins by ${cash(-savings)} over 3 years. Automation isn't always the answer, and that's the honest read.`;
      } else {
        verdict.textContent = "Dead even. Decide on headaches, not dollars.";
      }

      h("hva-payload").value = JSON.stringify({
        hours_per_week: hours,
        hourly_cost: rate,
        build_cost: build,
        upkeep_monthly: upkeep,
        automatable_pct: pct * 100,
        savings_3yr: Math.round(savings),
      });
    }

    ["hva-hours", "hva-rate", "hva-build", "hva-monthly", "hva-pct"].forEach(
      (id) => h(id).addEventListener("input", calcHva),
    );
    calcHva();

    const hvaForm = document.getElementById("hva-form") as HTMLFormElement;
    const hvaOk = document.getElementById("hva-form-success");
    hvaForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      try {
        const res = await fetch(hvaForm.action, {
          method: "POST",
          body: new FormData(hvaForm),
          headers: { Accept: "application/json" },
        });
        if (res.ok) {
          hvaForm.classList.add("hidden");
          hvaOk?.classList.remove("hidden");
        } else alert("Something went wrong. Please try again.");
      } catch {
        alert("Network error. Please try again.");
      }
    });
  </script>
</ToolShell>
