---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="generuss. | flawless by design"
  description="Web design, AI automation, and strategic analysis. Book a free discovery call."
>
  <main class="page">
    <h1 class="sr-only">generuss - Web Design and AI Strategy</h1>

    <!-- HEADER -->
    <header class="header" id="header">
      <div class="cb tl"></div><div class="cb tr"></div>
      <div class="cb bl"></div><div class="cb br"></div>
      <div class="header-content">
        <span class="brand">generuss<span class="dot">.</span></span>
        <div class="header-right">
          <span class="status-pulse"></span>
          <span class="status-text">available for work</span>
        </div>
      </div>
      <p class="header-sub">
        Websites that close leads, and the AI systems behind them.
      </p>
      <div class="glow-line">
        <div class="glow-line-shine"></div>
      </div>
    </header>

    <!-- CARDS -->
    <div class="cards">
      <!-- DESIGN CARD -->
      <section class="card card-design fade-in">
        <div class="shine-primary"></div>
        <div class="edge-top"></div>
        <div class="cyan-wash"></div>

        <!-- whole-card fallback link: anywhere not a slide/dot/link goes to the portfolio -->
        <a
          class="card-cover"
          href="https://generussdesign.com"
          target="_blank"
          rel="noopener noreferrer"
          aria-hidden="true"
          tabindex="-1"></a>

        <div class="card-content">
          <div class="card-label">// Recent Work</div>

          <div class="site-carousel" id="design-carousel">
            <a
              class="site-slide"
              href="https://generussdesign.com"
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="site-preview">
                <img
                  src="/images/slides/generuss.webp"
                  alt="generuss design - conversion-engineered websites"
                  class="site-preview-img"
                />
              </div>
              <div class="site-meta">
                <span class="site-name">generuss design</span>
                <span class="site-url"
                  >generussdesign.com <span class="ext">&#8599;</span></span
                >
              </div>
            </a>
            <a
              class="site-slide"
              href="https://tarotdoxa.com"
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="site-preview">
                <img
                  src="/images/slides/tarotdoxa.webp"
                  alt="Tarotdoxa - iPhone tarot app"
                  class="site-preview-img"
                  loading="lazy"
                />
              </div>
              <div class="site-meta">
                <span class="site-name">Tarotdoxa</span>
                <span class="site-url"
                  >iOS app · tarotdoxa.com <span class="ext">&#8599;</span
                  ></span
                >
              </div>
            </a>
            <a
              class="site-slide"
              href="https://crystalseedtarot.com"
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="site-preview">
                <img
                  src="/images/slides/crystal.webp"
                  alt="Crystal Seed Tarot screenshot"
                  class="site-preview-img"
                  loading="lazy"
                />
              </div>
              <div class="site-meta">
                <span class="site-name">Crystal Seed Tarot</span>
                <span class="site-url"
                  >crystalseedtarot.com <span class="ext">&#8599;</span></span
                >
              </div>
            </a>
            <a
              class="site-slide"
              href="https://vibenthrivetherapy.com"
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="site-preview">
                <img
                  src="/images/slides/vibe.webp"
                  alt="Vibe N Thrive Therapy screenshot"
                  class="site-preview-img"
                  loading="lazy"
                />
              </div>
              <div class="site-meta">
                <span class="site-name">Vibe'N Thrive</span>
                <span class="site-url"
                  >vibenthrivetherapy.com <span class="ext">&#8599;</span></span
                >
              </div>
            </a>
          </div>

          <div class="carousel-dots" id="design-dots">
            <button class="dot" type="button" aria-label="View generuss design"
            ></button>
            <button class="dot" type="button" aria-label="View Tarotdoxa"
            ></button>
            <button
              class="dot"
              type="button"
              aria-label="View Crystal Seed Tarot"></button>
            <button class="dot" type="button" aria-label="View Vibe N Thrive"
            ></button>
          </div>

          <div class="stats-row">
            <div class="stat-item">
              <span class="stat-val cyan-val">17+</span><span class="stat-label"
                >Shipped</span
              >
            </div>
            <div class="stat-sep"></div>
            <div class="stat-item">
              <span class="stat-val">5.0</span><span class="stat-label"
                >Rated</span
              >
            </div>
            <div class="stat-sep"></div>
            <div class="stat-item">
              <span class="stat-val">96</span><span class="stat-label"
                >Lighthouse</span
              >
            </div>
            <div class="stat-sep"></div>
            <div class="stat-item">
              <span class="stat-val">$0</span><span class="stat-label"
                >Hosting</span
              >
            </div>
          </div>

          <div class="reviews-wrap">
            <div class="reviews-track">
              <div class="review-chip">
                <div class="review-stars">
                  &#9733; &#9733; &#9733; &#9733; &#9733;
                </div>
                <div class="review-text">
                  "His ability to solve problems makes him a rare find."
                </div>
                <div class="review-author">Jonny - Invincible Media</div>
              </div>
              <div class="review-chip">
                <div class="review-stars">
                  &#9733; &#9733; &#9733; &#9733; &#9733;
                </div>
                <div class="review-text">
                  "I've never had anybody provide such detail to their work."
                </div>
                <div class="review-author">Carson - Vibe'N Thrive</div>
              </div>
              <div class="review-chip">
                <div class="review-stars">
                  &#9733; &#9733; &#9733; &#9733; &#9733;
                </div>
                <div class="review-text">
                  "Exceeded my expectations by miles."
                </div>
                <div class="review-author">
                  Leon McConnell - Resist Entertainment
                </div>
              </div>
              <div class="review-chip">
                <div class="review-stars">
                  &#9733; &#9733; &#9733; &#9733; &#9733;
                </div>
                <div class="review-text">
                  "You took a simple thing and brought it to life."
                </div>
                <div class="review-author">Dirty Chai - Struggle Crew</div>
              </div>
              <!-- Duplicate for seamless loop -->
              <div class="review-chip">
                <div class="review-stars">
                  &#9733; &#9733; &#9733; &#9733; &#9733;
                </div>
                <div class="review-text">
                  "His ability to solve problems makes him a rare find."
                </div>
                <div class="review-author">Jonny - Invincible Media</div>
              </div>
              <div class="review-chip">
                <div class="review-stars">
                  &#9733; &#9733; &#9733; &#9733; &#9733;
                </div>
                <div class="review-text">
                  "I've never had anybody provide such detail to their work."
                </div>
                <div class="review-author">Carson - Vibe'N Thrive</div>
              </div>
              <div class="review-chip">
                <div class="review-stars">
                  &#9733; &#9733; &#9733; &#9733; &#9733;
                </div>
                <div class="review-text">
                  "Exceeded my expectations by miles."
                </div>
                <div class="review-author">
                  Leon McConnell - Resist Entertainment
                </div>
              </div>
              <div class="review-chip">
                <div class="review-stars">
                  &#9733; &#9733; &#9733; &#9733; &#9733;
                </div>
                <div class="review-text">
                  "You took a simple thing and brought it to life."
                </div>
                <div class="review-author">Dirty Chai - Struggle Crew</div>
              </div>
            </div>
          </div>

          <a
            href="https://generussdesign.com"
            target="_blank"
            rel="noopener noreferrer"
            class="card-link"
          >
            See all work <span class="arrow">&rarr;</span>
          </a>
        </div>
      </section>

      <!-- PHARALLAX CARD (whole card clickable) -->
      <a
        href="https://pharallax.ai"
        target="_blank"
        rel="noopener noreferrer"
        class="card card-pharallax fade-in"
      >
        <div class="shine-primary"></div>
        <div class="edge-top"></div>
        <div class="cyan-wash"></div>

        <div class="card-label">// Strategic Analysis</div>

        <div class="pharallax-headline">
          The structural risk<br /><span class="glow">nobody mentioned.</span>
        </div>

        <div class="site-preview-wrap">
          <div class="site-preview">
            <img
              src="/images/slides/pharallax.webp"
              alt="Pharallax.ai - AI strategic analysis engine"
              class="site-preview-img"
              loading="lazy"
            />
          </div>
          <div class="site-meta">
            <span class="site-name">Pharallax</span>
            <span class="site-url"
              >pharallax.ai <span class="ext">&#8599;</span></span
            >
          </div>
        </div>

        <div class="pharallax-stat">
          <span class="collision-count">630K+</span>
          <span class="collision-unit">structured claims · 160 domains</span>
        </div>

        <span class="card-link">
          Explore Pharallax <span class="arrow">&rarr;</span>
        </span>
        <span class="card-sub"
          >free analysis in 2 min · full Structural Read $497</span
        >
      </a>

      <!-- TAROTDOXA CARD (whole card clickable) -->
      <a
        href="https://tarotdoxa.com"
        target="_blank"
        rel="noopener noreferrer"
        class="card card-tarotdoxa fade-in"
      >
        <div class="shine-primary"></div>
        <div class="edge-top"></div>

        <div class="tarot-inner">
          <div class="tarot-media">
            <div class="site-preview">
              <img
                src="/images/slides/tarotdoxa-hero.webp"
                alt="Tarotdoxa - the painterly TAROTDOXA wordmark over a dancing figure"
                class="site-preview-img tarot-hero-img"
                width="1280"
                height="720"
                loading="lazy"
              />
            </div>
          </div>

          <div class="tarot-body">
            <div class="card-label">// iPhone Tarot App</div>
            <div class="tarot-headline">
              Meaning isn't added.<br /><span class="tarot-glow"
                >It's revealed.</span
              >
            </div>
            <p class="tarot-desc">
              A tarot app with a real reader's voice. Every reading reaches
              beneath the surface and reveals what was already there.
            </p>
            <span class="card-link tarot-link">
              Enter Tarotdoxa <span class="arrow">&rarr;</span>
            </span>
            <span class="card-sub tarot-sub"
              >tarotdoxa.com &middot; coming to iOS, summer 2026</span
            >
          </div>
        </div>
      </a>

      <!-- BOOK A CALL -->
      <a
        href="https://app.cal.com/generuss/discovery-call"
        target="_blank"
        rel="noopener noreferrer"
        class="card card-cta fade-in"
      >
        <div class="shine-primary faint-shine"></div>
        <div class="cta-content">
          <div class="cta-huge">
            Let's<br /><span class="glow">build.</span>
          </div>
          <div class="cta-right">
            <span class="cta-btn"
              >Book a Call <span class="arrow">&rarr;</span></span
            >
            <p class="cta-sub">15 min. Your screen. No pitch.</p>
          </div>
        </div>
      </a>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
