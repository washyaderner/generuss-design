<style is:global>
  body:has(> .page) {
    background: #0d0d10 !important;
  }
</style>

<style>
  /* ---- ROTATING BORDER PROPERTY ---- */
  @property --glow-angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  /* ---- TOKENS ---- */
  .page {
    --b-bg: #0d0d10;
    --b-base: #1a1a1e;
    --b-surface: #222226;
    --b-sdark: #0b0b0d;
    --b-slight: #2a2a30;
    --b-cyan: #00ffef;
    --b-cyan-bright: #66fff5;
    --b-glow: rgba(0, 255, 239, 0.35);
    --b-mid: rgba(0, 255, 239, 0.2);
    --b-dim: rgba(0, 255, 239, 0.1);
    --b-faint: rgba(0, 255, 239, 0.05);
    --b-txt: #e8e8e8;
    --b-txt2: #9a9aa0;
    --b-txt3: #6b6b75;
    --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
    --font-mono:
      "JetBrains Mono", ui-monospace, "SF Mono", "Fira Code", monospace;
  }

  /* ---- RESET ---- */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* ---- PAGE ---- */
  .page {
    background: var(--b-bg);
    min-height: 100dvh;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 480px;
    margin: 0 auto;
    font-family: var(--font-sans);
    color: var(--b-txt);
    -webkit-font-smoothing: antialiased;
  }

  /* ---- HEADER ---- */
  .header {
    position: relative;
    background: var(--b-base);
    border-radius: 16px;
    padding: 20px 24px 16px;
    overflow: hidden;
    box-shadow:
      3px 3px 7px var(--b-sdark),
      -2px -2px 5px var(--b-slight),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .header::before {
    content: "";
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1;
  }
  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 3;
    margin-bottom: 10px;
  }
  .brand {
    font-family: var(--font-sans);
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -1px;
    color: var(--b-txt);
  }
  .dot {
    color: var(--b-cyan);
    text-shadow:
      0 0 10px var(--b-glow),
      0 0 40px var(--b-dim);
  }
  .header-right {
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .status-pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--b-cyan);
    box-shadow: 0 0 4px var(--b-mid);
    animation: pulse-glow 2.5s ease-in-out infinite;
    flex-shrink: 0;
  }
  .status-text {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--b-txt3);
  }
  .header-sub {
    position: relative;
    z-index: 3;
    margin: 0 0 16px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    line-height: 1.45;
    color: var(--b-txt2);
    max-width: 30ch;
  }

  /* Glow line */
  .glow-line {
    height: 2px;
    background: var(--b-cyan);
    border-radius: 2px;
    position: relative;
    z-index: 3;
    box-shadow:
      0 0 8px rgba(0, 255, 239, 0.5),
      0 0 20px rgba(0, 255, 239, 0.25),
      0 0 40px rgba(0, 255, 239, 0.12);
  }
  .glow-line-shine {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 5%,
      rgba(255, 255, 255, 0.25) 15%,
      rgba(255, 255, 255, 0.5) 45%,
      rgba(255, 255, 255, 0.6) 50%,
      rgba(255, 255, 255, 0.5) 55%,
      rgba(255, 255, 255, 0.25) 85%,
      transparent 95%
    );
    border-radius: 2px;
  }

  /* Corner brackets */
  .cb {
    position: absolute;
    width: 12px;
    height: 12px;
    z-index: 4;
    pointer-events: none;
  }
  .cb::before,
  .cb::after {
    content: "";
    position: absolute;
    background: var(--b-txt3);
    opacity: 0.15;
  }
  .cb::before {
    height: 1px;
    width: 12px;
  }
  .cb::after {
    width: 1px;
    height: 12px;
  }
  .cb.tl {
    top: 10px;
    left: 10px;
  }
  .cb.tl::before {
    top: 0;
    left: 0;
  }
  .cb.tl::after {
    top: 0;
    left: 0;
  }
  .cb.tr {
    top: 10px;
    right: 10px;
  }
  .cb.tr::before {
    top: 0;
    right: 0;
  }
  .cb.tr::after {
    top: 0;
    right: 0;
  }
  .cb.bl {
    bottom: 10px;
    left: 10px;
  }
  .cb.bl::before {
    bottom: 0;
    left: 0;
  }
  .cb.bl::after {
    bottom: 0;
    left: 0;
  }
  .cb.br {
    bottom: 10px;
    right: 10px;
  }
  .cb.br::before {
    bottom: 0;
    right: 0;
  }
  .cb.br::after {
    bottom: 0;
    right: 0;
  }

  /* ---- CARDS CONTAINER ---- */
  .cards {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ---- CARD BASE ---- */
  .card {
    border-radius: 16px;
    background: var(--b-base);
    position: relative;
    overflow: hidden;
    box-shadow:
      3px 3px 7px var(--b-sdark),
      -2px -2px 5px var(--b-slight),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  a.card {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: box-shadow 0.25s ease;
  }
  a.card:hover,
  .card-design:hover {
    box-shadow:
      3px 3px 7px var(--b-sdark),
      -2px -2px 5px var(--b-slight),
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 0 20px var(--b-dim);
  }

  /* Noise texture */
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1;
  }

  /* Decorative layers */
  .shine-primary {
    position: absolute;
    top: -32%;
    left: -16%;
    width: 62%;
    height: 72%;
    background: radial-gradient(
      ellipse,
      rgba(255, 255, 255, 0.05) 0%,
      transparent 68%
    );
    pointer-events: none;
    z-index: 2;
  }
  .faint-shine {
    opacity: 0.5;
  }
  .edge-top {
    position: absolute;
    top: 0;
    left: 8%;
    right: 40%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.08) 40%,
      transparent
    );
    z-index: 3;
    pointer-events: none;
  }
  .cyan-wash {
    position: absolute;
    bottom: -5%;
    left: 10%;
    right: 10%;
    height: 40%;
    background: radial-gradient(
      ellipse at center bottom,
      var(--b-faint) 0%,
      transparent 60%
    );
    pointer-events: none;
    z-index: 2;
  }

  /* Whole-card cover link (Recent Work) */
  .card-cover {
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: 16px;
  }
  .card-content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    pointer-events: none;
  }
  /* re-enable pointer events only on the genuinely interactive bits */
  .card-content .card-link,
  .card-content .dot {
    pointer-events: auto;
  }

  /* ---- SHARED CARD ELEMENTS ---- */
  .card-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--b-txt3);
    padding: 20px 24px 0;
    position: relative;
    z-index: 3;
  }
  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--b-txt3);
    text-decoration: none;
    padding: 0 24px;
    position: relative;
    z-index: 3;
    transition: color 0.2s;
    width: fit-content;
  }
  .card-link:hover,
  .card-design:hover .card-link,
  .card-pharallax:hover .card-link {
    color: var(--b-cyan);
  }
  .arrow {
    font-size: 13px;
    transition: transform 0.2s ease;
  }
  .card-link:hover .arrow,
  .card-pharallax:hover .arrow {
    transform: translateX(3px);
  }

  .card-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.5px;
    color: var(--b-txt3);
    padding: 6px 24px 20px;
    position: relative;
    z-index: 3;
  }

  /* ---- DESIGN CARD ---- */
  .card-design {
    display: flex;
    flex-direction: column;
    padding: 0;
    transition: box-shadow 0.25s ease;
  }

  /* Site carousel */
  .site-carousel {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    background: var(--b-sdark);
    box-shadow:
      inset 3px 3px 8px rgba(0, 0, 0, 0.5),
      inset -2px -2px 6px rgba(46, 46, 51, 0.3);
    margin: 12px 24px 0;
    aspect-ratio: 16 / 9;
    z-index: 3;
  }
  .site-slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.6s ease;
  }
  /* no-JS fallback: show the first project */
  .site-carousel:not(.ready) .site-slide:first-child {
    opacity: 1;
    pointer-events: auto;
  }
  .site-carousel.ready .site-slide.active {
    opacity: 1;
    pointer-events: auto;
  }
  .site-preview {
    flex: 1;
    position: relative;
    overflow: hidden;
    background: var(--b-sdark);
  }
  .site-preview-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.4s ease;
  }
  .site-slide:hover .site-preview-img {
    transform: scale(1.03);
  }
  .site-meta {
    padding: 8px 14px;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    transition: background 0.2s ease;
  }
  .site-slide:hover .site-meta {
    background: rgba(0, 0, 0, 0.55);
  }
  .site-name {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    color: var(--b-txt);
  }
  .site-url {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    color: var(--b-txt3);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }
  .ext {
    color: var(--b-cyan);
    font-size: 11px;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }
  .site-slide:hover .ext {
    opacity: 1;
    text-shadow: 0 0 6px var(--b-mid);
  }

  /* Carousel dots */
  .carousel-dots {
    display: none;
    justify-content: center;
    align-items: center;
    gap: 7px;
    padding: 12px 24px 0;
    position: relative;
    z-index: 3;
  }
  .carousel-dots.ready {
    display: flex;
  }
  .carousel-dots .dot {
    width: 7px;
    height: 7px;
    padding: 0;
    border: 0;
    border-radius: 9999px;
    background: var(--b-txt3);
    opacity: 0.35;
    cursor: pointer;
    transition:
      width 0.25s ease,
      opacity 0.2s ease,
      background 0.2s ease;
  }
  .carousel-dots .dot:hover {
    opacity: 0.7;
  }
  .carousel-dots .dot.active {
    width: 18px;
    opacity: 1;
    background: var(--b-cyan);
    box-shadow: 0 0 6px var(--b-mid);
  }

  /* Stats row */
  .stats-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 14px 24px;
    position: relative;
    z-index: 3;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    flex-wrap: wrap;
  }
  .stat-item {
    display: flex;
    align-items: baseline;
    gap: 6px;
    padding: 0 12px;
    white-space: nowrap;
  }
  .stat-val {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.5px;
    color: var(--b-txt);
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 8px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--b-txt3);
  }
  .cyan-val {
    color: var(--b-cyan);
    text-shadow: 0 0 8px var(--b-dim);
  }
  .stat-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--b-txt3);
    opacity: 0.2;
    flex-shrink: 0;
  }

  /* Reviews ticker */
  .reviews-wrap {
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    overflow: hidden;
    min-height: 68px;
    max-height: 90px;
    position: relative;
    z-index: 3;
  }
  .reviews-wrap::before,
  .reviews-wrap::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 40px;
    z-index: 4;
    pointer-events: none;
  }
  .reviews-wrap::before {
    left: 0;
    background: linear-gradient(90deg, var(--b-base), transparent);
  }
  .reviews-wrap::after {
    right: 0;
    background: linear-gradient(270deg, var(--b-base), transparent);
  }
  .reviews-track {
    display: flex;
    height: 100%;
    animation: scroll-reviews 24s linear infinite;
  }
  .review-chip {
    flex-shrink: 0;
    padding: 14px 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    border-right: 1px solid rgba(255, 255, 255, 0.03);
    min-width: 280px;
  }
  .review-stars {
    font-size: 11px;
    color: var(--b-cyan);
    letter-spacing: 2px;
    text-shadow: 0 0 6px var(--b-dim);
  }
  .review-text {
    font-family: var(--font-sans);
    font-size: 13px;
    font-style: italic;
    color: var(--b-txt);
    line-height: 1.45;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .review-author {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    color: var(--b-txt3);
    letter-spacing: 1px;
  }

  /* Design card CTA */
  .card-design .card-content > .card-link {
    padding: 12px 24px 16px;
  }

  /* ---- PHARALLAX CARD ---- */
  a.card-pharallax {
    display: flex;
    flex-direction: column;
    padding: 0;
  }
  /* Rotating cyan glow border - the signature treatment */
  .card-pharallax::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 16px;
    padding: 1.5px;
    background: conic-gradient(
      from var(--glow-angle),
      transparent 0deg,
      transparent 205deg,
      var(--b-cyan) 285deg,
      var(--b-cyan-bright) 300deg,
      var(--b-cyan) 315deg,
      transparent 350deg,
      transparent 360deg
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    mask-composite: exclude;
    animation: glow-rotate 7s linear infinite;
    pointer-events: none;
    z-index: 5;
  }
  .pharallax-headline {
    font-family: var(--font-sans);
    font-size: 22px;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.5px;
    color: var(--b-txt);
    padding: 14px 24px 0;
    position: relative;
    z-index: 3;
  }
  .pharallax-headline .glow {
    color: var(--b-cyan);
    text-shadow:
      0 0 15px var(--b-glow),
      0 0 40px var(--b-dim);
  }
  .site-preview-wrap {
    margin: 14px 24px 0;
    border-radius: 10px;
    overflow: hidden;
    background: var(--b-sdark);
    box-shadow:
      inset 3px 3px 8px rgba(0, 0, 0, 0.5),
      inset -2px -2px 6px rgba(46, 46, 51, 0.3);
    position: relative;
    z-index: 3;
  }
  .site-preview-wrap .site-preview {
    aspect-ratio: 16 / 9;
  }
  .card-pharallax:hover .site-preview-img {
    transform: scale(1.03);
  }
  .pharallax-stat {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 16px 24px 10px;
    position: relative;
    z-index: 3;
  }
  .collision-count {
    font-family: var(--font-sans);
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -1px;
    color: var(--b-cyan);
    text-shadow: 0 0 10px var(--b-mid);
  }
  .collision-unit {
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--b-txt3);
  }

  /* Pharallax CTA */
  .card-pharallax > .card-link {
    padding: 0 24px;
  }
  .card-pharallax > .card-sub {
    padding: 4px 24px 16px;
  }

  /* ---- TAROTDOXA CARD ---- */
  a.card-tarotdoxa {
    display: block;
    padding: 0;
  }
  .card-tarotdoxa .tarot-inner {
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 3;
  }
  .tarot-media {
    position: relative;
    z-index: 3;
  }
  .tarot-media .site-preview {
    aspect-ratio: 16 / 9;
    width: 100%;
    background: var(--b-sdark);
  }
  .card-tarotdoxa .tarot-hero-img {
    object-position: center;
  }
  .card-tarotdoxa:hover .tarot-hero-img {
    transform: scale(1.03);
  }
  .tarot-body {
    display: flex;
    flex-direction: column;
    padding: 16px 24px 20px;
  }
  .tarot-body .card-label {
    padding: 0;
  }
  .tarot-headline {
    font-family: var(--font-sans);
    font-size: 21px;
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.5px;
    color: var(--b-txt);
    margin-top: 12px;
  }
  .tarot-glow {
    background: linear-gradient(
      90deg,
      #ff7ab8 0%,
      #c08cff 48%,
      var(--b-cyan-bright) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .tarot-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--b-txt2);
    margin: 10px 0 0;
    max-width: 46ch;
  }
  .tarot-body .card-link.tarot-link {
    padding: 14px 0 0;
  }
  .tarot-body .card-sub.tarot-sub {
    padding: 7px 0 0;
  }
  .card-tarotdoxa:hover .card-link {
    color: var(--b-cyan);
  }
  .card-tarotdoxa:hover .arrow {
    transform: translateX(3px);
  }

  /* ---- CTA CARD ---- */
  .card-cta {
    padding: 24px;
  }
  .card-cta:hover {
    box-shadow:
      3px 3px 7px var(--b-sdark),
      -2px -2px 5px var(--b-slight),
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 0 24px var(--b-dim);
  }
  .cta-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    position: relative;
    z-index: 3;
  }
  .cta-huge {
    font-family: var(--font-sans);
    font-size: clamp(40px, 11vw, 60px);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -2.5px;
    color: var(--b-txt);
  }
  .glow {
    color: var(--b-cyan);
    text-shadow:
      0 0 15px var(--b-glow),
      0 0 40px var(--b-dim);
  }
  .cta-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--b-cyan);
    color: #0c0c0c;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: -0.2px;
    padding: 11px 20px;
    border-radius: 9999px;
    white-space: nowrap;
    transition:
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }
  .card-cta:hover .cta-btn {
    box-shadow: 0 0 24px var(--b-mid);
    transform: translateY(-1px);
  }
  .card-cta:hover .cta-btn .arrow {
    transform: translateX(3px);
  }
  .cta-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--b-txt3);
    text-align: right;
    max-width: 150px;
    line-height: 1.5;
    margin: 0;
  }

  /* ---- FOOTER ---- */
  .footer {
    padding: 8px 0 16px;
  }
  .social-row {
    display: flex;
    gap: 10px;
    justify-content: center;
  }
  .social-icon {
    width: 48px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: var(--b-base);
    color: var(--b-txt2);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow:
      inset 2px 2px 5px var(--b-sdark),
      inset -1px -1px 3px var(--b-slight);
  }
  .social-icon:hover {
    color: var(--b-cyan);
    box-shadow:
      inset 2px 2px 5px var(--b-sdark),
      inset -1px -1px 3px var(--b-slight),
      0 0 8px var(--b-dim);
  }
  .social-icon svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
    display: block;
  }
  .social-handle {
    margin-top: 10px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--b-txt3);
    text-align: center;
    letter-spacing: 1px;
  }

  /* ---- STICKY PILL ---- */
  .sticky-pill {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--b-cyan);
    color: #0c0c0c;
    border-radius: 9999px;
    padding: 12px 26px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: -0.2px;
    text-decoration: none;
    box-shadow:
      0 0 18px var(--b-mid),
      0 6px 16px rgba(0, 0, 0, 0.5);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease,
      box-shadow 0.2s ease;
    z-index: 100;
    opacity: 0;
    pointer-events: none;
  }
  .sticky-pill.visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  .sticky-pill:hover {
    box-shadow:
      0 0 28px var(--b-glow),
      0 6px 16px rgba(0, 0, 0, 0.5);
  }

  /* ---- FADE IN ---- */
  .fade-in {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .fade-in:nth-child(1) {
    transition-delay: 0s;
  }
  .fade-in:nth-child(2) {
    transition-delay: 0.1s;
  }
  .fade-in:nth-child(3) {
    transition-delay: 0.2s;
  }
  .fade-in:nth-child(4) {
    transition-delay: 0.3s;
  }

  /* ---- ANIMATIONS ---- */
  @keyframes pulse-glow {
    0%,
    100% {
      opacity: 1;
      box-shadow: 0 0 4px var(--b-mid);
    }
    50% {
      opacity: 0.5;
      box-shadow: 0 0 8px var(--b-glow);
    }
  }

  @keyframes scroll-reviews {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @keyframes glow-rotate {
    to {
      --glow-angle: 360deg;
    }
  }

  /* ---- REDUCED MOTION ---- */
  @media (prefers-reduced-motion: reduce) {
    .reviews-track {
      animation-play-state: paused;
    }
    .status-pulse {
      animation: none;
    }
    .card-pharallax::after {
      animation: none;
      background: conic-gradient(
        from 300deg,
        transparent 0deg,
        var(--b-cyan) 40deg,
        transparent 80deg,
        transparent 360deg
      );
    }
    .site-slide {
      transition: none;
    }
    .site-preview-img {
      transition: none;
    }
    .fade-in {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .sticky-pill {
      transition: none;
    }
  }

  /* ---- TABLET (640px+) ---- */
  @media (min-width: 640px) {
    .page {
      max-width: 560px;
      padding: 20px;
      gap: 14px;
    }
    .cards {
      gap: 14px;
    }
  }

  /* ---- DESKTOP (1024px+) ---- */
  @media (min-width: 1024px) {
    .page {
      max-width: 1100px;
      padding: 24px;
      gap: 16px;
    }

    .header {
      padding: 24px 32px 20px;
    }
    .header-sub {
      font-size: 14px;
    }

    .cards {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 16px;
    }

    /* Restore full depth */
    .card {
      box-shadow:
        6px 6px 14px var(--b-sdark),
        -4px -4px 10px var(--b-slight),
        inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }
    a.card:hover,
    .card-design:hover {
      box-shadow:
        6px 6px 14px var(--b-sdark),
        -4px -4px 10px var(--b-slight),
        inset 0 1px 0 rgba(255, 255, 255, 0.05),
        0 0 24px var(--b-dim);
    }

    .card-design {
      grid-column: 1;
      grid-row: 1;
    }
    .card-pharallax {
      grid-column: 2;
      grid-row: 1;
    }
    .card-tarotdoxa {
      grid-column: 1 / -1;
      grid-row: 2;
    }
    .card-cta {
      grid-column: 1 / -1;
      grid-row: 3;
    }

    /* Tarotdoxa becomes a horizontal hero banner on desktop */
    .card-tarotdoxa .tarot-inner {
      flex-direction: row;
      align-items: center;
    }
    .card-tarotdoxa .tarot-media {
      flex: 0 0 56%;
    }
    .card-tarotdoxa .tarot-body {
      flex: 1;
      padding: 28px 36px;
    }
    .card-tarotdoxa .tarot-headline {
      font-size: 27px;
      margin-top: 0;
    }
    .card-tarotdoxa .tarot-desc {
      font-size: 14px;
    }

    .cta-huge {
      font-size: clamp(48px, 5vw, 72px);
    }

    /* Hide sticky pill on desktop */
    .sticky-pill {
      display: none;
    }

    .social-icon {
      width: 52px;
      height: 44px;
    }
  }
</style>

<script>
  // ---- Carousel: dynamic per-slide links + dots + pause on interaction ----
  const carousel = document.getElementById("design-carousel");
  const dotsWrap = document.getElementById("design-dots");
  if (carousel && dotsWrap) {
    const slides = Array.from(carousel.querySelectorAll(".site-slide"));
    const dots = Array.from(dotsWrap.querySelectorAll(".dot"));
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    let idx = 0;
    let timer;

    carousel.classList.add("ready");
    dotsWrap.classList.add("ready");

    const show = (i) => {
      idx = (i + slides.length) % slides.length;
      slides.forEach((s, j) => s.classList.toggle("active", j === idx));
      dots.forEach((d, j) => d.classList.toggle("active", j === idx));
    };
    const stop = () => {
      if (timer) {
        clearInterval(timer);
        timer = undefined;
      }
    };
    const start = () => {
      if (reduce) return;
      stop();
      timer = setInterval(() => show(idx + 1), 4500);
    };

    show(0);
    start();

    dots.forEach((d, j) =>
      d.addEventListener("click", (e) => {
        e.preventDefault();
        show(j);
        start();
      }),
    );
    carousel.addEventListener("mouseenter", stop);
    carousel.addEventListener("mouseleave", start);
    carousel.addEventListener("focusin", stop);
    carousel.addEventListener("focusout", start);
  }

  // ---- Sticky pill: show when header scrolls out of view ----
  const pill = document.getElementById("sticky-pill");
  const header = document.getElementById("header");
  if (pill && header) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        pill.classList.toggle("visible", !entry.isIntersecting);
      },
      { threshold: 0 },
    );
    observer.observe(header);
  }

  // ---- Fade-in on scroll ----
  const fadeEls = document.querySelectorAll(".fade-in");
  if (fadeEls.length) {
    const fadeObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            fadeObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 },
    );
    fadeEls.forEach((el) => fadeObserver.observe(el));
  }
</script>
