---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="generuss. | flawless by design"
  description="Web design, AI automation, and strategic analysis. Book a free discovery call."
>
  <main class="page">
    <h1 class="sr-only">generuss - Web Design and AI Strategy</h1>

    <!-- HEADER -->
    <header class="header" id="header">
      <div class="cb tl"></div><div class="cb tr"></div>
      <div class="cb bl"></div><div class="cb br"></div>
      <div class="header-content">
        <span class="brand">generuss<span class="dot">.</span></span>
        <div class="header-right">
          <span class="status-pulse"></span>
          <span class="tagline">flawless by design</span>
        </div>
      </div>
      <div class="glow-line">
        <div class="glow-line-shine"></div>
      </div>
    </header>

    <!-- CARDS -->
    <div class="cards">
      <!-- DESIGN CARD -->
      <section class="card card-design fade-in">
        <div class="shine-primary"></div>
        <div class="edge-top"></div>
        <div class="cyan-wash"></div>

        <div class="card-label">// Recent Work</div>

        <div class="site-carousel">
          <div class="site-slide">
            <div class="site-preview">
              <img
                src="/images/slides/generuss.webp"
                alt="generuss design screenshot"
                class="site-preview-img"
              />
            </div>
            <div class="site-meta">
              <span class="site-name">generuss design</span>
              <span class="site-url">generussdesign.com</span>
            </div>
          </div>
          <div class="site-slide">
            <div class="site-preview">
              <img
                src="/images/slides/vibe.webp"
                alt="Vibe N Thrive Therapy screenshot"
                class="site-preview-img"
                loading="lazy"
              />
            </div>
            <div class="site-meta">
              <span class="site-name">Vibe'N Thrive</span>
              <span class="site-url">vibenthrivetherapy.com</span>
            </div>
          </div>
          <div class="site-slide">
            <div class="site-preview">
              <img
                src="/images/slides/crystal.webp"
                alt="Crystal Seed Tarot screenshot"
                class="site-preview-img"
                loading="lazy"
              />
            </div>
            <div class="site-meta">
              <span class="site-name">Crystal Seed Tarot</span>
              <span class="site-url">crystalseedtarot.com</span>
            </div>
          </div>
        </div>

        <div class="stats-row">
          <div class="stat-item">
            <span class="stat-val cyan-val">5</span><span class="stat-label"
              >Sites Live</span
            >
          </div>
          <div class="stat-sep"></div>
          <div class="stat-item">
            <span class="stat-val">4hr</span><span class="stat-label"
              >Fastest</span
            >
          </div>
          <div class="stat-sep"></div>
          <div class="stat-item">
            <span class="stat-val">$0</span><span class="stat-label"
              >Hosting</span
            >
          </div>
          <div class="stat-sep"></div>
          <div class="stat-item">
            <span class="stat-val">100</span><span class="stat-label"
              >Lighthouse</span
            >
          </div>
        </div>

        <div class="reviews-wrap">
          <div class="reviews-track">
            <div class="review-chip">
              <div class="review-stars">
                &#9733; &#9733; &#9733; &#9733; &#9733;
              </div>
              <div class="review-text">
                "His ability to solve problems makes him a rare find."
              </div>
              <div class="review-author">Jonny - Invincible Media</div>
            </div>
            <div class="review-chip">
              <div class="review-stars">
                &#9733; &#9733; &#9733; &#9733; &#9733;
              </div>
              <div class="review-text">
                "I've never had anybody provide such detail to their work."
              </div>
              <div class="review-author">Carson - Vibe'N Thrive</div>
            </div>
            <div class="review-chip">
              <div class="review-stars">
                &#9733; &#9733; &#9733; &#9733; &#9733;
              </div>
              <div class="review-text">
                "Exceeded my expectations by miles."
              </div>
              <div class="review-author">
                Leon McConnell - Resist Entertainment
              </div>
            </div>
            <div class="review-chip">
              <div class="review-stars">
                &#9733; &#9733; &#9733; &#9733; &#9733;
              </div>
              <div class="review-text">
                "You took a simple thing and brought it to life."
              </div>
              <div class="review-author">Dirty Chai - Struggle Crew</div>
            </div>
            <div class="review-chip">
              <div class="review-stars">
                &#9733; &#9733; &#9733; &#9733; &#9733;
              </div>
              <div class="review-text">
                "Made it smarter, faster, and sharper."
              </div>
              <div class="review-author">Jonny - Invincible Media</div>
            </div>
            <!-- Duplicate for seamless loop -->
            <div class="review-chip">
              <div class="review-stars">
                &#9733; &#9733; &#9733; &#9733; &#9733;
              </div>
              <div class="review-text">
                "His ability to solve problems makes him a rare find."
              </div>
              <div class="review-author">Jonny - Invincible Media</div>
            </div>
            <div class="review-chip">
              <div class="review-stars">
                &#9733; &#9733; &#9733; &#9733; &#9733;
              </div>
              <div class="review-text">
                "I've never had anybody provide such detail to their work."
              </div>
              <div class="review-author">Carson - Vibe'N Thrive</div>
            </div>
            <div class="review-chip">
              <div class="review-stars">
                &#9733; &#9733; &#9733; &#9733; &#9733;
              </div>
              <div class="review-text">
                "Exceeded my expectations by miles."
              </div>
              <div class="review-author">
                Leon McConnell - Resist Entertainment
              </div>
            </div>
            <div class="review-chip">
              <div class="review-stars">
                &#9733; &#9733; &#9733; &#9733; &#9733;
              </div>
              <div class="review-text">
                "You took a simple thing and brought it to life."
              </div>
              <div class="review-author">Dirty Chai - Struggle Crew</div>
            </div>
            <div class="review-chip">
              <div class="review-stars">
                &#9733; &#9733; &#9733; &#9733; &#9733;
              </div>
              <div class="review-text">
                "Made it smarter, faster, and sharper."
              </div>
              <div class="review-author">Jonny - Invincible Media</div>
            </div>
          </div>
        </div>

        <a
          href="https://generussdesign.com"
          target="_blank"
          rel="noopener noreferrer"
          class="card-link"
        >
          See the work <span class="arrow">&rarr;</span>
        </a>
      </section>

      <!-- PHARALLAX CARD -->
      <section class="card card-pharallax fade-in">
        <div class="shine-primary gold-shine"></div>
        <div class="edge-top gold-edge"></div>
        <div class="gold-wash"></div>

        <div class="card-label gold-label">// Strategic Analysis</div>

        <div class="pharallax-headline">Stress-test your strategy</div>

        <div class="site-preview-wrap">
          <div class="site-preview">
            <img
              src="/images/slides/pharallax.webp"
              alt="Pharallax.ai - AI strategic analysis engine"
              class="site-preview-img"
              loading="lazy"
            />
          </div>
          <div class="site-meta gold-meta">
            <span class="site-name">Pharallax</span>
            <span class="site-url">pharallax.ai</span>
          </div>
        </div>

        <div class="pharallax-stat">
          <span class="collision-count">60K+</span>
          <span class="collision-unit">claims analyzed</span>
        </div>

        <a
          href="https://pharallax.ai/analyze"
          target="_blank"
          rel="noopener noreferrer"
          class="card-link gold-link"
        >
          Run a free analysis <span class="arrow">&rarr;</span>
        </a>
        <span class="card-sub">your solution in 2 minutes, free</span>
      </section>

      <!-- BOOK A CALL -->
      <a
        href="https://app.cal.com/generuss/discovery-call"
        target="_blank"
        rel="noopener noreferrer"
        class="card card-cta fade-in"
      >
        <div class="shine-primary faint-shine"></div>
        <div class="cta-content">
          <div class="cta-huge">
            Let's<br /><span class="glow">build.</span>
          </div>
          <div class="cta-right">
            <p class="cta-sub">15 min. Your screen. No pitch.</p>
          </div>
        </div>
      </a>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
      <div class="social-row">
        <a
          href="https://x.com/generussai"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="X / Twitter">X</a
        >
        <a
          href="https://github.com/washyaderner"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="GitHub">GH</a
        >
        <a
          href="https://www.youtube.com/@generussai"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="YouTube">YT</a
        >
        <a
          href="https://www.linkedin.com/in/russell-gardner-382b6037/"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="LinkedIn">LI</a
        >
      </div>
      <div class="social-handle">@generussai</div>
    </footer>

    <!-- STICKY PILL -->
    <a
      href="https://app.cal.com/generuss/discovery-call"
      target="_blank"
      rel="noopener noreferrer"
      class="sticky-pill"
      id="sticky-pill"
      aria-label="Book a 15-minute call"
    >
      Book 15 min
    </a>
  </main>
</BaseLayout>

<style is:global>
  body:has(> .page) {
    background: #0e0e10 !important;
  }
</style>

<style>
  /* ---- TOKENS ---- */
  .page {
    --b-base: #1a1a1e;
    --b-surface: #222226;
    --b-sdark: #0d0d0f;
    --b-slight: #2e2e33;
    --b-cyan: #00ffef;
    --b-glow: rgba(0, 255, 239, 0.35);
    --b-mid: rgba(0, 255, 239, 0.2);
    --b-dim: rgba(0, 255, 239, 0.1);
    --b-faint: rgba(0, 255, 239, 0.05);
    --b-txt: #e8e8e8;
    --b-txt2: #9a9aa0;
    --b-txt3: #6b6b75;
    --b-gold: #c8a84e;
    --b-gold-bright: #e0c060;
    --b-gold-dim: #8b7535;
    --b-gold-glow: rgba(200, 168, 78, 0.35);
    --b-gold-mid: rgba(200, 168, 78, 0.2);
    --b-gold-faint: rgba(200, 168, 78, 0.05);
    --b-premortem: #e04040;
    --b-dialectic: #4080e0;
    --b-reflexive: #40c080;
    --font-mono:
      "JetBrains Mono", ui-monospace, "SF Mono", "Fira Code", monospace;
  }

  /* ---- RESET ---- */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* ---- PAGE ---- */
  .page {
    background: #0e0e10;
    min-height: 100dvh;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 480px;
    margin: 0 auto;
  }

  /* ---- HEADER ---- */
  .header {
    position: relative;
    background: var(--b-base);
    border-radius: 16px;
    padding: 20px 24px 16px;
    overflow: hidden;
  }
  .header::before {
    content: "";
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1;
  }
  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 3;
    margin-bottom: 16px;
  }
  .brand {
    font-family: var(--font-mono);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--b-txt2);
  }
  .dot {
    color: var(--b-cyan);
    text-shadow:
      0 0 10px var(--b-glow),
      0 0 40px var(--b-dim);
  }
  .header-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .status-pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--b-cyan);
    box-shadow: 0 0 4px var(--b-mid);
    animation: pulse-glow 2.5s ease-in-out infinite;
    flex-shrink: 0;
  }
  .tagline {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: lowercase;
    color: var(--b-txt3);
  }

  /* Glow line */
  .glow-line {
    height: 2px;
    background: var(--b-cyan);
    border-radius: 2px;
    position: relative;
    z-index: 3;
    box-shadow:
      0 0 8px rgba(0, 255, 239, 0.5),
      0 0 20px rgba(0, 255, 239, 0.25),
      0 0 40px rgba(0, 255, 239, 0.12);
  }
  .glow-line-shine {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 5%,
      rgba(255, 255, 255, 0.25) 15%,
      rgba(255, 255, 255, 0.5) 45%,
      rgba(255, 255, 255, 0.6) 50%,
      rgba(255, 255, 255, 0.5) 55%,
      rgba(255, 255, 255, 0.25) 85%,
      transparent 95%
    );
    border-radius: 2px;
  }

  /* Corner brackets */
  .cb {
    position: absolute;
    width: 12px;
    height: 12px;
    z-index: 4;
    pointer-events: none;
  }
  .cb::before,
  .cb::after {
    content: "";
    position: absolute;
    background: var(--b-txt3);
    opacity: 0.15;
  }
  .cb::before {
    height: 1px;
    width: 12px;
  }
  .cb::after {
    width: 1px;
    height: 12px;
  }
  .cb.tl {
    top: 10px;
    left: 10px;
  }
  .cb.tl::before {
    top: 0;
    left: 0;
  }
  .cb.tl::after {
    top: 0;
    left: 0;
  }
  .cb.tr {
    top: 10px;
    right: 10px;
  }
  .cb.tr::before {
    top: 0;
    right: 0;
  }
  .cb.tr::after {
    top: 0;
    right: 0;
  }
  .cb.bl {
    bottom: 10px;
    left: 10px;
  }
  .cb.bl::before {
    bottom: 0;
    left: 0;
  }
  .cb.bl::after {
    bottom: 0;
    left: 0;
  }
  .cb.br {
    bottom: 10px;
    right: 10px;
  }
  .cb.br::before {
    bottom: 0;
    right: 0;
  }
  .cb.br::after {
    bottom: 0;
    right: 0;
  }

  /* ---- CARDS CONTAINER ---- */
  .cards {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ---- CARD BASE ---- */
  .card {
    border-radius: 16px;
    background: var(--b-base);
    position: relative;
    overflow: hidden;
    box-shadow:
      3px 3px 7px var(--b-sdark),
      -2px -2px 5px var(--b-slight),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  a.card {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: box-shadow 0.25s ease;
  }
  a.card:hover {
    box-shadow:
      3px 3px 7px var(--b-sdark),
      -2px -2px 5px var(--b-slight),
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 0 20px var(--b-dim);
  }

  /* Noise texture */
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1;
  }

  /* Decorative layers */
  .shine-primary {
    position: absolute;
    top: -32%;
    left: -16%;
    width: 62%;
    height: 72%;
    background: radial-gradient(
      ellipse,
      rgba(255, 255, 255, 0.05) 0%,
      transparent 68%
    );
    pointer-events: none;
    z-index: 2;
  }
  .faint-shine {
    opacity: 0.5;
  }
  .gold-shine {
    background: radial-gradient(
      ellipse,
      rgba(200, 168, 78, 0.04) 0%,
      transparent 68%
    );
  }
  .edge-top {
    position: absolute;
    top: 0;
    left: 8%;
    right: 40%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.08) 40%,
      transparent
    );
    z-index: 3;
    pointer-events: none;
  }
  .gold-edge {
    background: linear-gradient(
      90deg,
      transparent,
      rgba(200, 168, 78, 0.12) 40%,
      transparent
    );
  }
  .cyan-wash {
    position: absolute;
    bottom: -5%;
    left: 10%;
    right: 10%;
    height: 40%;
    background: radial-gradient(
      ellipse at center bottom,
      var(--b-faint) 0%,
      transparent 60%
    );
    pointer-events: none;
    z-index: 2;
  }
  .gold-wash {
    position: absolute;
    bottom: -5%;
    left: 10%;
    right: 10%;
    height: 40%;
    background: radial-gradient(
      ellipse at center bottom,
      var(--b-gold-faint) 0%,
      transparent 60%
    );
    pointer-events: none;
    z-index: 2;
  }

  /* ---- SHARED CARD ELEMENTS ---- */
  .card-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--b-txt3);
    padding: 20px 24px 0;
    position: relative;
    z-index: 3;
  }
  .gold-label {
    color: var(--b-gold-dim);
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--b-txt3);
    text-decoration: none;
    padding: 0 24px;
    position: relative;
    z-index: 3;
    transition: color 0.2s;
  }
  .card-link:hover {
    color: var(--b-cyan);
  }
  .gold-link:hover {
    color: var(--b-gold-bright);
  }
  .arrow {
    font-size: 13px;
  }

  .card-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 1px;
    color: var(--b-txt3);
    padding: 6px 24px 20px;
    position: relative;
    z-index: 3;
  }

  /* ---- DESIGN CARD ---- */
  .card-design {
    display: flex;
    flex-direction: column;
    padding: 0;
  }

  /* Site carousel */
  .site-carousel {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    background: var(--b-sdark);
    box-shadow:
      inset 3px 3px 8px rgba(0, 0, 0, 0.5),
      inset -2px -2px 6px rgba(46, 46, 51, 0.3);
    margin: 12px 24px 0;
    aspect-ratio: 16 / 9;
    z-index: 3;
  }
  .site-slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    opacity: 0;
    animation: site-fade 12s infinite;
  }
  .site-slide:nth-child(1) {
    animation-delay: 0s;
  }
  .site-slide:nth-child(2) {
    animation-delay: 4s;
  }
  .site-slide:nth-child(3) {
    animation-delay: 8s;
  }
  .site-preview {
    flex: 1;
    position: relative;
    overflow: hidden;
    background: var(--b-sdark);
  }
  .site-preview-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }
  .site-meta {
    padding: 8px 14px;
    background: rgba(0, 0, 0, 0.35);
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
  }
  .site-name {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--b-txt);
  }
  .site-url {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    color: var(--b-txt3);
  }

  /* Stats row */
  .stats-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 14px 24px;
    position: relative;
    z-index: 3;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    flex-wrap: wrap;
  }
  .stat-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0 12px;
    font-family: var(--font-mono);
    white-space: nowrap;
  }
  .stat-val {
    font-size: 14px;
    font-weight: 700;
    color: var(--b-txt);
  }
  .stat-label {
    font-size: 8px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--b-txt3);
  }
  .cyan-val {
    color: var(--b-cyan);
    text-shadow: 0 0 8px var(--b-dim);
  }
  .stat-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--b-txt3);
    opacity: 0.2;
    flex-shrink: 0;
