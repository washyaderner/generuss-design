<style is:global>
  body:has(> .connect-page) {
    background: #0e0e10;
  }
</style>

<style>
  /* ─── TOKENS ─── */
  .connect-page {
    --b-base: #1a1a1e;
    --b-surface: #222226;
    --b-sdark: #0d0d0f;
    --b-slight: #2e2e33;
    --b-cyan: #00ffef;
    --b-glow: rgba(0, 255, 239, 0.35);
    --b-mid: rgba(0, 255, 239, 0.2);
    --b-dim: rgba(0, 255, 239, 0.1);
    --b-faint: rgba(0, 255, 239, 0.05);
    --b-txt: #e8e8e8;
    --b-txt2: #9a9aa0;
    --b-txt3: #6b6b75;
  }

  /* ─── PAGE WRAPPER ─── */
  .connect-page {
    background: #0e0e10;
    padding: 12px;
    min-height: 100dvh;
  }

  /* ─── BENTO GRID ─── */
  .bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    width: 100%;
    min-height: 0;
  }

  /* ─── CARD BASE ─── */
  .card {
    border-radius: 16px;
    background: var(--b-base);
    position: relative;
    overflow: hidden;
    min-height: 0;
    min-width: 0;
  }

  a.card {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: box-shadow 0.25s ease;
  }

  /* Noise texture */
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1;
  }

  /* ─── DEPTH SYSTEM ─── */
  .depth-subtle {
    box-shadow:
      4px 4px 10px var(--b-sdark),
      -3px -3px 8px var(--b-slight),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }
  .depth-raised {
    box-shadow:
      6px 6px 14px var(--b-sdark),
      -4px -4px 10px var(--b-slight),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .depth-heavy {
    box-shadow:
      3px 3px 6px var(--b-sdark),
      8px 8px 20px var(--b-sdark),
      -3px -3px 8px var(--b-slight),
      -6px -6px 16px var(--b-slight),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .depth-inset {
    box-shadow:
      inset 4px 4px 10px var(--b-sdark),
      inset -3px -3px 8px var(--b-slight);
  }
  .depth-deep {
    box-shadow:
      inset 6px 6px 16px var(--b-sdark),
      inset -3px -3px 10px var(--b-slight);
  }
  .depth-canyon {
    box-shadow:
      inset 3px 3px 6px var(--b-sdark),
      inset 6px 6px 16px rgba(13, 13, 15, 0.8),
      inset 12px 12px 36px rgba(13, 13, 15, 0.5),
      inset -2px -2px 6px var(--b-slight),
      inset -4px -4px 14px rgba(46, 46, 51, 0.6),
      inset -8px -8px 30px rgba(46, 46, 51, 0.25);
  }

  /* ─── DECORATIVE LAYERS ─── */
  .shine-primary {
    position: absolute;
    top: -32%;
    left: -16%;
    width: 62%;
    height: 72%;
    background: radial-gradient(
      ellipse,
      rgba(255, 255, 255, 0.05) 0%,
      transparent 68%
    );
    pointer-events: none;
    z-index: 2;
  }
  .dim-shine {
    opacity: 0.7;
  }
  .faint-shine {
    opacity: 0.5;
  }

  .shine-specular {
    position: absolute;
    top: -20%;
    left: 15%;
    width: 35%;
    height: 40%;
    background: radial-gradient(
      ellipse,
      rgba(255, 255, 255, 0.025) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 2;
  }

  .edge-top {
    position: absolute;
    top: 0;
    left: 8%;
    right: 40%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.08) 40%,
      transparent
    );
    z-index: 3;
    pointer-events: none;
  }
  .edge-left {
    position: absolute;
    left: 0;
    top: 5%;
    bottom: 50%;
    width: 1px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), transparent);
    z-index: 3;
    pointer-events: none;
  }

  /* Corner brackets */
  .cb {
    position: absolute;
    width: 12px;
    height: 12px;
    z-index: 4;
    pointer-events: none;
  }
  .cb::before,
  .cb::after {
    content: "";
    position: absolute;
    background: var(--b-txt3);
    opacity: 0.15;
  }
  .cb::before {
    height: 1px;
    width: 12px;
  }
  .cb::after {
    width: 1px;
    height: 12px;
  }
  .cb.tl {
    top: 10px;
    left: 10px;
  }
  .cb.tl::before {
    top: 0;
    left: 0;
  }
  .cb.tl::after {
    top: 0;
    left: 0;
  }
  .cb.tr {
    top: 10px;
    right: 10px;
  }
  .cb.tr::before {
    top: 0;
    right: 0;
  }
  .cb.tr::after {
    top: 0;
    right: 0;
  }
  .cb.bl {
    bottom: 10px;
    left: 10px;
  }
  .cb.bl::before {
    bottom: 0;
    left: 0;
  }
  .cb.bl::after {
    bottom: 0;
    left: 0;
  }
  .cb.br {
    bottom: 10px;
    right: 10px;
  }
  .cb.br::before {
    bottom: 0;
    right: 0;
  }
  .cb.br::after {
    bottom: 0;
    right: 0;
  }

  /* ─── TYPOGRAPHY ─── */
  .card-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--b-txt3);
    margin-bottom: 10px;
    position: relative;
    z-index: 2;
  }
  .no-mb {
    margin-bottom: 0;
  }

  .card-title {
    font-weight: 800;
    font-size: 18px;
    line-height: 1.25;
    margin-bottom: 6px;
    color: var(--b-txt);
    position: relative;
    z-index: 2;
  }
  .card-desc {
    font-size: 13px;
    color: var(--b-txt2);
    line-height: 1.55;
    position: relative;
    z-index: 2;
  }
  .hot-text {
    color: var(--b-cyan);
    text-shadow:
      0 0 10px var(--b-glow),
      0 0 30px var(--b-dim);
  }
  .hot-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--b-cyan);
    box-shadow:
      0 0 5px var(--b-mid),
      0 0 12px var(--b-dim);
    display: inline-block;
    flex-shrink: 0;
  }
  .cyan-val {
    color: var(--b-cyan);
    text-shadow: 0 0 8px var(--b-dim);
  }

  /* ─── HERO CARD ─── */
  .hero {
    display: flex;
    flex-direction: column;
    padding: 0;
    min-height: 380px;
  }

  .hero .cyan-wash {
    position: absolute;
    bottom: -5%;
    left: 10%;
    right: 10%;
    height: 40%;
    background: radial-gradient(
      ellipse at center bottom,
      var(--b-faint) 0%,
      transparent 60%
    );
    pointer-events: none;
    z-index: 2;
  }

  .hero-header {
    padding: 20px 24px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 3;
    flex-shrink: 0;
  }
  .hero-brand {
    font-size: 24px;
    font-weight: 900;
    letter-spacing: -0.5px;
    color: var(--b-txt2);
    text-decoration: none;
  }
  .hero-brand .dot {
    color: var(--b-cyan);
    text-shadow:
      0 0 10px var(--b-glow),
      0 0 40px var(--b-dim);
  }
  .hero-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--b-txt3);
  }
  .status-pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--b-cyan);
    box-shadow: 0 0 4px var(--b-mid);
    animation: pulse-glow 2.5s ease-in-out infinite;
  }

  /* Site carousel */
  .hero-sites {
    padding: 14px 24px;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    position: relative;
    z-index: 3;
    overflow: hidden;
  }
  .sites-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .sites-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--b-txt3);
  }
  .carousel-dots {
    display: flex;
    gap: 5px;
  }
  .carousel-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--b-txt3);
    opacity: 0.25;
    transition: all 0.4s ease;
  }
  .carousel-dot.active {
    background: var(--b-cyan);
    opacity: 1;
    box-shadow: 0 0 4px var(--b-dim);
  }

  .site-carousel {
    flex: 1;
    min-height: 0;
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    background: var(--b-sdark);
    box-shadow:
      inset 3px 3px 8px rgba(0, 0, 0, 0.5),
      inset -2px -2px 6px rgba(46, 46, 51, 0.3);
  }

  .site-slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    opacity: 0;
    animation: site-fade 12s infinite;
  }
  .site-slide:nth-child(1) {
    animation-delay: 0s;
  }
  .site-slide:nth-child(2) {
    animation-delay: 4s;
  }
  .site-slide:nth-child(3) {
    animation-delay: 8s;
  }

  .site-preview {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  /* CSS art site previews */
