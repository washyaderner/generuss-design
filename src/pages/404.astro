---
import BlogLayout from "../layouts/BlogLayout.astro";
---

<BlogLayout
  title="Page Not Found | generuss design"
  description="The page you're looking for doesn't exist."
>
  <div
    class="flex min-h-[60vh] flex-col items-center justify-center px-8 text-center"
  >
    <p class="font-mono text-sm text-accent mb-4">404</p>
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
      Page not found.
    </h1>
    <p class="text-lg text-text-muted mb-8 max-w-md">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="rounded-full bg-accent px-8 py-3 text-base font-semibold text-[#0C0C0C] transition-shadow duration-200 hover:shadow-[0_0_30px_var(--color-accent-mid)]"
    >
      Back to Home &rarr;
    </a>
  </div>
</BlogLayout>
